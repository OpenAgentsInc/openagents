{
  "name": "@openagentsinc/aiur",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vp dev --config vite.config.cloudrun.ts",
    "build": "pnpm run build:cloudrun",
    "preview": "vp preview --config vite.config.cloudrun.ts",
    "deploy": "pnpm run deploy:cloudrun",
    "build:cloudrun": "vp build --config vite.config.cloudrun.ts --logLevel warn && vp pack src/cloudrun/server.ts --format esm --platform node --out-dir dist/cloudrun",
    "deploy:cloudrun": "bash scripts/deploy-cloudrun.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect-native/tokens": "workspace:*",
    "@openagentsinc/effect-start": "workspace:*",
    "@openagentsinc/khala-sync": "workspace:*",
    "@openagentsinc/khala-sync-client": "workspace:*",
    "@openagentsinc/khala-sync-db-collection": "workspace:*",
    "@openagentsinc/runtime-platform": "workspace:*",
    "@openauthjs/openauth": "^0.4.3",
    "@radix-ui/react-slot": "^1.2.5",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/react-start-client": "1.168.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "4.0.0-beta.94",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vite": "^8.0.13",
    "vitest": "^4.1.8"
  }
