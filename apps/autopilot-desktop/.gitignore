# #5027: the bundled headless Pylon node, produced by `bun run build:pylon-node`
# (`bun build ../pylon/src/index.ts --target bun`) and copied into the packaged
# `.app` at Resources/app/pylon-node/index.js so a packaged install can launch
# the local node. A generated artifact built before `electrobun build`, never
# committed (Pylon's source home is apps/pylon).
resources/pylon-node/

# P0 StyleX migration: generated browser webview bundle produced by
# `bun run build:css`. Electrobun consumes this compiled entry so raw
# `stylex.create(...)` calls never reach the packaged browser view.
resources/ui/

# CL-53: generated Tailwind output (built by `bun run build:css`, copied into
# the view bundle as styles.css). The build now appends extracted StyleX CSS as
# well. The styles.css SOURCE is committed; this generated artifact is not.
src/ui/styles.out.css

# Electrobun build output
build/

# Electrobun release artifacts (.dmg / .app.tar.zst / update.json) produced by
# `electrobun build --env=canary|stable`. These are large binaries and OTA feed
# inputs, not source — published to the OTA bucket, never committed.
artifacts/

# Temporary Chrome/CDP harness output from `bun run smoke:training-scene`.
.training-scene-smoke-*/

# Temporary Chrome/CDP harness scratch dirs (auto-cleaned, but ignored in case a
# crashed run leaves one): the headless pixel harness and the app replica.
.headless-render-*/
.app-replica-*/
