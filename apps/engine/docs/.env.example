# Required API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default GitHub Repository (optional, can be overridden by script args)
GITHUB_REPO_OWNER=openagentsinc
GITHUB_REPO_NAME=openagents

# Script-Specific Configuration
# RUN_SCRIPT_OWNER - GitHub repository owner for issue (overrides GITHUB_REPO_OWNER)
# RUN_SCRIPT_REPO - GitHub repository name for issue (overrides GITHUB_REPO_NAME)
# RUN_SCRIPT_ISSUE - GitHub issue number to process (default: 796)
# RUN_SCRIPT_INSTANCE_ID - Optional ID of existing agent state to load/resume
# RUN_SCRIPT_MAX_STEPS - Maximum number of steps to execute (default: 20)
# RUN_SCRIPT_VERBOSE - Enable verbose logging (set to "true" for debug info)

# Example Usage
# RUN_SCRIPT_OWNER=openagentsinc
# RUN_SCRIPT_REPO=openagents
# RUN_SCRIPT_ISSUE=796
# RUN_SCRIPT_INSTANCE_ID=solver-openagentsinc-openagents-796-1714042123456
# RUN_SCRIPT_MAX_STEPS=30
# RUN_SCRIPT_VERBOSE=true