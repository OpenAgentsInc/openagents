{
  "extends": "./tsconfig.src.json",
  "compilerOptions": {
    "types": ["node"],
    "tsBuildInfoFile": ".tsbuildinfo/build.tsbuildinfo",
    "outDir": "build/esm",
    "declarationDir": "build/dts",
    "stripInternal": true
  },
  "include": ["src/**/*"],
  "files": [
    "src/index.ts",
    "src/Program.ts",
    "src/Server.ts"
  ]
}
