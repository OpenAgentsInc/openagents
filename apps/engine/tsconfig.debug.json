{
  "extends": "./tsconfig.src.json",
  "compilerOptions": {
    "types": ["node"],
    "tsBuildInfoFile": ".tsbuildinfo/debug.tsbuildinfo",
    "outDir": "build/debug",
    "declarationDir": "build/dts",
    "stripInternal": true,
    "noEmitOnError": false
  },
  "include": ["src/**/*"],
  "exclude": ["test/**/*"],
  "files": [
    "src/index.ts",
    "src/Program.ts",
    "src/Server.ts",
    "src/github/PlanManager.ts"
  ]
}