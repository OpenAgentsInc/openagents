.{
    .id = "com.openagents.native-sdk-effect-native-spike",
    .name = "native-sdk-effect-native-spike",
    .display_name = "Native SDK × Effect Native",
    .description = "A bounded Native SDK host and Effect Native renderer-adoption spike.",
    .version = "0.1.0",
    .icons = .{"assets/icon.png"},
    .platforms = .{"macos"},
    .permissions = .{ "view", "command" },
    .capabilities = .{ "native_views", "gpu_surfaces", "webview", "js_bridge", "shortcuts" },
    .bridge = .{
        .commands = .{
            .{ .name = "openagents.spike.projection.v1", .origins = .{ "zero://app", "http://127.0.0.1:5173" } },
        },
    },
    .shell = .{
        .windows = .{
            .{
                .label = "main",
                .title = "OpenAgents Native parity spike",
                .width = 1200,
                .height = 800,
                .min_width = 760,
                .min_height = 520,
                .titlebar = "hidden_inset",
                .restore_state = false,
                .restore_policy = "center_on_primary",
                .views = .{
                    .{ .label = "native-shell", .kind = "gpu_surface", .fill = true, .role = "Native SDK shell", .accessibility_label = "Native SDK component shell", .gpu_backend = "metal", .gpu_pixel_format = "bgra8_unorm", .gpu_present_mode = "timer", .gpu_alpha_mode = "opaque", .gpu_color_space = "srgb", .gpu_vsync = true },
                    .{ .label = "effect-native-surface", .kind = "webview", .parent = "native-shell", .url = "zero://app/index.html#surface=effect-native", .x = 232, .y = 0, .width = 968, .height = 800, .layer = 20 },
                },
            },
        },
    },
    .frontend = .{
        .dist = "frontend/dist",
        .entry = "index.html",
        .spa_fallback = true,
        .dev = .{
            .url = "http://127.0.0.1:5173/",
            .command = .{ "pnpm", "run", "dev:frontend" },
            .ready_path = "/",
            .timeout_ms = 30000,
        },
    },
    .security = .{
        .navigation = .{
            .allowed_origins = .{ "zero://app", "http://127.0.0.1:5173" },
            .external_links = .{ .action = "deny" },
        },
    },
    .web_engine = "system",
    .cef = .{ .dir = "third_party/cef/macos", .auto_install = false },
}
