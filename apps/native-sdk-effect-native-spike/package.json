{
  "name": "@openagentsinc/native-sdk-effect-native-spike",
  "version": "0.1.0",
  "private": true,
  "description": "A bounded Native SDK host and Effect Native renderer-adoption spike.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:frontend": "vp dev --host 127.0.0.1",
    "build:frontend": "vp build",
    "build:native": "zig build",
    "build:native:automation": "zig build -Dautomation=true",
    "test:native": "zig build test",
    "test": "vp test --run frontend/src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "pnpm run build:native:automation && node --import tsx scripts/run-host-smoke.ts",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run build:frontend && pnpm run test:native && pnpm run build:native && pnpm run smoke"
  },
  "dependencies": {
    "@effect-native/core": "workspace:*",
    "@effect-native/render-dom": "workspace:*",
    "@effect-native/tokens": "workspace:*",
    "@openagentsinc/openagents-desktop": "workspace:*",
    "effect": "catalog:",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "0.2.4"
  }
}
