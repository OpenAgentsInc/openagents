# OpenAgents NIP-05 registrar environment.
# Copy to a private location (e.g. /etc/openagents/nip05.env), fill in real
# values, and load via your service supervisor. Never commit a real token.

# REQUIRED. Long random secret, e.g. `openssl rand -hex 32`.
NIP05_REGISTRAR_ADMIN_TOKEN=replace-with-long-random-secret

# Optional. TCP socket the service binds.
# NIP05_REGISTRAR_LISTEN_ADDR=127.0.0.1:8088

# Optional. Absolute path to the live nostr.json (must be writable).
# NIP05_REGISTRAR_DATA_FILE=/var/lib/openagents/nip05/nostr.json

# Optional. Extra comma-separated reserved handles, e.g. "founder,launch".
# NIP05_REGISTRAR_RESERVED_EXTRA=

# Optional. tracing env filter.
# RUST_LOG=warn,nip05_registrar=info
