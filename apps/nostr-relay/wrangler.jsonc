{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "openagents-market-relay",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-09",
  "workers_dev": true,
  "preview_urls": true,
  // Canonical public market-relay domain (#4863). The workers.dev URL
  // stays live for compatibility; relay.openagents.com is the published
  // ref strangers and providers should use.
  "routes": [
    { "pattern": "relay.openagents.com", "custom_domain": true },
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
  "vars": {
    "OPENAGENTS_NOSTR_RELAY_ISSUE": "https://github.com/OpenAgentsInc/openagents/issues/4636",
    "RELAY_NAME": "OpenAgents Scoped Market Relay",
    "RELAY_DESCRIPTION": "Scoped OpenAgents market-event relay for NIP-90, NIP-DS, and NIP-89 transport. It grants no payment, identity, moderation, assignment, or settlement authority.",
    "RELAY_CONTACT": "https://github.com/OpenAgentsInc/openagents/issues/4636",
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "NOSTR_RELAY",
        "class_name": "NostrRelayDO",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["NostrRelayDO"],
    },
  ],
}
