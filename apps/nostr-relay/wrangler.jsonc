{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "openagents-nostr-relay-poc",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-09",
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
  "vars": {
    "OPENAGENTS_NOSTR_RELAY_ISSUE": "https://github.com/OpenAgentsInc/openagents/issues/4621",
    "RELAY_NAME": "OpenAgents Nostr Relay POC",
    "RELAY_DESCRIPTION": "Proof-of-concept OpenAgents Nostr relay backed by a Cloudflare Durable Object and nostr-effect.",
    "RELAY_CONTACT": "https://github.com/OpenAgentsInc/openagents/issues/4621",
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "NOSTR_RELAY",
        "class_name": "NostrRelayDO",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["NostrRelayDO"],
    },
  ],
}
