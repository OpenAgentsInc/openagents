{
  "name": "@openagentsinc/oa-queue-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CFG-7 (#8522): Cloud Run pump for the oa-infra Postgres JobQueue — leases jobs (FOR UPDATE SKIP LOCKED) and delivers them to the app's internal queue delivery route.",
  "scripts": {
    "test": "bun test src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "bun build src/main.ts --target=bun --outdir dist --entry-naming server.js",
    "serve": "bun run src/main.ts",
    "deploy": "bash scripts/deploy-cloudrun.sh"
  },
  "dependencies": {
    "@openagentsinc/oa-infra": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "bun-types": "^1.0.0",
    "typescript": "catalog:"
  }
}
