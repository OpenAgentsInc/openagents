{
  "name": "@openagentsinc/openagents-audio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --import tsx src/main.ts",
    "test": "vp test --run src test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:cloudrun": "vp pack src/main.ts --format esm --platform node --out-dir dist",
    "deploy:cloudrun": "bash scripts/deploy-cloudrun.sh",
    "smoke:live": "node --import tsx scripts/live-retention-smoke.ts",
    "smoke:tts:live": "node --import tsx scripts/live-tts-smoke.ts",
    "smoke:barge:live": "node --import tsx scripts/live-barge-smoke.ts"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.2.1",
    "@google-cloud/text-to-speech": "^6.4.1",
    "@openagentsinc/audio-contract": "workspace:*",
    "@openagentsinc/postgres-runtime": "workspace:*",
    "@openagentsinc/runtime-platform": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
