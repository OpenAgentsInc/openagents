{
  "compilerOptions": {
    "target": "ES2024", "module": "ESNext", "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true, "strict": true, "skipLibCheck": true,
    "noEmit": true, "types": ["node", "vite-plus-matchers"], "exactOptionalPropertyTypes": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "test/**/*.ts"]
}
