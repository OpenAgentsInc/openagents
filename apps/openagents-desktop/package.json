{
  "name": "@openagentsinc/openagents-desktop",
  "version": "0.1.0-rc.17",
  "private": true,
  "description": "OpenAgents — Effect Native application on an Electron host (#8574).",
  "license": "MIT",
  "type": "module",
  "main": "dist/main.js",
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "build": "node --import tsx scripts/build.ts",
    "package:mac": "electron-forge package --platform=darwin --arch=arm64",
    "make:mac": "node --import tsx scripts/prepare-macos-maker.ts && electron-forge make --platform=darwin --arch=arm64",
    "dev": "node --import tsx scripts/dev.ts",
    "full-auto": "node --import tsx scripts/full-auto-cli.ts",
    "live-proof": "node --import tsx scripts/build.ts && node --import tsx scripts/run-live-proof.ts",
    "mvp-proof": "node --import tsx scripts/build.ts && node --import tsx scripts/run-mvp-proof.ts",
    "release-acceptance": "node --import tsx scripts/run-release-acceptance.ts",
    "smoke:artifact:codex-runtime": "node --import tsx scripts/codex-runtime-artifact-smoke.ts",
    "smoke:codex-supervisor": "node --import tsx scripts/codex-app-server-supervisor-smoke.ts",
    "smoke:codex-ecosystem": "node --import tsx scripts/codex-ecosystem-smoke.ts",
    "smoke:codex-host-services": "node --import tsx scripts/codex-host-services-smoke.ts",
    "smoke:codex-experimental": "node --import tsx scripts/codex-experimental-runtime-smoke.ts",
    "smoke:codex-binary-manifest": "node --import tsx scripts/codex-binary-manifest-smoke.ts",
    "generate:codex-conformance": "node --import tsx scripts/generate-codex-conformance-report.ts",
    "smoke:codex-control-plane": "node --import tsx scripts/codex-control-plane-smoke.ts",
    "smoke:codex-thread-lifecycle": "node --import tsx scripts/codex-thread-lifecycle-smoke.ts",
    "smoke:codex-turn-control": "node --import tsx scripts/codex-turn-control-smoke.ts",
    "smoke": "node --import tsx scripts/build.ts && OPENAGENTS_DESKTOP_SMOKE=1 electron .",
    "smoke:full-auto-control": "node --import tsx scripts/full-auto-control-smoke.ts",
    "smoke:full-auto-restart": "node --import tsx scripts/full-auto-restart-smoke.ts",
    "smoke:react": "node --import tsx scripts/build.ts && OPENAGENTS_DESKTOP_SMOKE=1 OPENAGENTS_DESKTOP_SMOKE_REACT=1 electron .",
    "smoke:headed": "node --import tsx scripts/build.ts && OPENAGENTS_DESKTOP_SMOKE=1 OPENAGENTS_DESKTOP_HEADED=1 electron .",
    "startup-bench": "node --import tsx scripts/startup-bench.ts",
    "test": "vp test --run --max-concurrency 1 --root ../.. apps/openagents-desktop",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run build && OPENAGENTS_DESKTOP_SMOKE=1 pnpm run smoke && pnpm run smoke:react"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.172",
    "@base-ui/react": "^1.6.0",
    "@effect-native/core": "workspace:*",
    "@effect-native/render-dom": "workspace:*",
    "@effect-native/tokens": "workspace:*",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/oxanium": "^5.2.8",
    "@lexical/react": "^0.41.0",
    "@openagentsinc/agent-client-runtime-bridge": "workspace:*",
    "@openagentsinc/assurance-spec": "workspace:*",
    "@openagentsinc/audio-contract": "workspace:*",
    "@openagentsinc/behavior-contracts": "workspace:*",
    "@openagentsinc/codex-app-server-protocol": "workspace:*",
    "@openagentsinc/environment-auth": "workspace:*",
    "@openagentsinc/khala-sync": "workspace:*",
    "@openagentsinc/khala-sync-client": "workspace:*",
    "@openagentsinc/product-spec": "workspace:*",
    "@openagentsinc/pylon-core": "workspace:*",
    "@openagentsinc/runtime-platform": "workspace:*",
    "@openagentsinc/ui": "workspace:*",
    "@openai/codex": "0.144.1",
    "@openai/codex-darwin-arm64": "npm:@openai/codex@0.144.1-darwin-arm64",
    "@shadcn/react": "^0.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "effect": "catalog:",
    "lexical": "^0.41.0",
    "lucide-react": "^1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-dmg": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron-forge/shared-types": "7.11.2",
    "@electron/fuses": "2.1.3",
    "@openagentsinc/sqlite-runtime": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^43.1.0",
    "happy-dom": "^20.10.6",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "0.2.4"
  },
  "productName": "OpenAgents"
}
