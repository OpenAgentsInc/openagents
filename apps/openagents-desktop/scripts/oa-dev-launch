#!/bin/zsh

emulate -L zsh
setopt pipefail

source_repo="$HOME/work/openagents"
launch_repo="$HOME/work/.oa-launch"
node24_bin="$HOME/.nvm/versions/node/v24.13.1/bin"
owner_launch_cwd="$PWD"
restart_requested=false
restart_root="$HOME/Library/Logs/OpenAgents/oa-dev-restarts"
generation_path="$restart_root/current-generation.json"

record_generation() {
  local generation_pid="$1"
  local generation_pgid="$2"
  local generation_start="$3"
  local generation_commit="$4"
  local generation_token="$5"
  node -e '
    const fs=require("node:fs"), path=require("node:path"); const p=process.argv[1], next=`${p}.next-${process.pid}`;
    const d={schemaVersion:"openagents.desktop.dev_generation.v1",generationToken:process.argv[2],devPid:Number(process.argv[3]),processGroupId:Number(process.argv[4]),processStartIdentity:process.argv[5],launchCommit:process.argv[6],launchRepo:process.argv[7],recordedAt:new Date().toISOString()};
    fs.writeFileSync(next,`${JSON.stringify(d,null,2)}\n`,{mode:0o600}); const f=fs.openSync(next,"r");fs.fsyncSync(f);fs.closeSync(f);fs.renameSync(next,p);const dir=fs.openSync(path.dirname(p),"r");fs.fsyncSync(dir);fs.closeSync(dir);
  ' "$generation_path" "$generation_token" "$generation_pid" "$generation_pgid" "$generation_start" "$generation_commit" "$launch_repo"
}

if [[ "${1:-}" == "--restart" ]]; then
  restart_requested=true
  shift
  if (( $# != 0 )); then
    echo "oa-dev: --restart does not accept dev-server arguments" >&2
    exit 64
  fi
fi
if [[ "${1:-}" == "--restart-supervisor" ]]; then
  echo "oa-dev: internal restart supervision is launchd-owned; use oa-dev --restart" >&2
  exit 64
fi

if [[ -x "$node24_bin/node" ]]; then
  export PATH="$node24_bin:$PATH"
fi
if [[ "$(node --version 2>/dev/null)" != "v24.13.1" ]]; then
  echo "oa-dev: Node 24.13.1 is required" >&2
  exit 1
fi
if ! git -C "$source_repo" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "oa-dev: $source_repo is not a usable Git worktree" >&2
  exit 1
fi

echo "oa-dev: fetching origin/main"
git -C "$source_repo" fetch --quiet origin main || exit 1

# Primary-main hygiene is best-effort here, never launch authority. The
# dedicated launch worktree below is the exact clean origin/main runtime.
if [[ "$(git -C "$source_repo" branch --show-current)" == "main" &&
      -z "$(git -C "$source_repo" status --porcelain)" ]]; then
  git -C "$source_repo" merge --ff-only --quiet origin/main ||
    echo "oa-dev: note: primary main did not fast-forward; using isolated launch worktree"
else
  echo "oa-dev: note: primary checkout is busy; using isolated launch worktree"
fi

managed_status="$(node -e '
  try {
    const fs = require("node:fs"), cp = require("node:child_process");
    const g = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const ps = (args) => cp.spawnSync("/bin/ps", args, {encoding:"utf8"});
    const pgid = ps(["-o","pgid=","-p",String(g.devPid)]);
    const start = ps(["-o","lstart=","-p",String(g.devPid)]);
    if (pgid.status === 0 && start.status === 0 && Number(pgid.stdout.trim()) === g.processGroupId && start.stdout.trim() === g.processStartIdentity)
        process.stdout.write(`leader:${g.devPid}`);
    else {
      const groups = ps(["-axo","pgid="]);
      if (groups.status === 0 && groups.stdout.split(/\s+/).some((value) => Number(value) === g.processGroupId))
        process.stdout.write(`orphan:${g.processGroupId}`);
    }
  } catch {}
' "$generation_path")"
managed_pid=""
recorded_orphan_pgid=""
if [[ "$managed_status" == leader:* ]]; then
  managed_pid="${managed_status#leader:}"
elif [[ "$managed_status" == orphan:* ]]; then
  recorded_orphan_pgid="${managed_status#orphan:}"
fi
managed_pgid=""
if [[ -n "$managed_pid" ]]; then
  managed_pgid="$(/bin/ps -o pgid= -p "$managed_pid" | tr -d '[:space:]')"
fi
existing_pid=""
owned_unmanaged_pid=""
blocking_unmanaged_pid=""
for candidate in ${(f)"$(pgrep -x 'OpenAgents Dev' 2>/dev/null)"}; do
  candidate_pgid="$(/bin/ps -o pgid= -p "$candidate" | tr -d '[:space:]')"
  if [[ -n "$managed_pgid" && "$candidate_pgid" == "$managed_pgid" ]]; then existing_pid="$candidate"; break; fi
  candidate_executable="$(/usr/sbin/lsof -a -p "$candidate" -d txt -Fn 2>/dev/null | sed -n 's/^n//p' | head -1)"
  if [[ "$candidate_executable" == "$launch_repo/"*"/Electron.app/Contents/MacOS/Electron" ]]; then
    if [[ -n "$owned_unmanaged_pid" ]]; then
      echo "oa-dev: multiple launcher-owned OpenAgents Dev processes exist; refusing ambiguous recovery" >&2
      exit 1
    fi
    owned_unmanaged_pid="$candidate"
  elif [[ -n "$candidate_pgid" ]]; then
    # Preview and smoke apps deliberately use OS-temporary profiles and may
    # run beside the stable Dev app. Their process group carries that typed
    # profile path on a Chromium child; they neither own nor read .oa-launch.
    isolated_profile_group="$(/bin/ps -axo pgid=,command= | awk -v pgid="$candidate_pgid" '$1 == pgid { $1=""; print substr($0,2) }' | grep -E -- '--user-data-dir=.*/openagents-desktop-(smoke-|preview\.)' | head -1)"
    if [[ -z "$isolated_profile_group" ]]; then
      blocking_unmanaged_pid="$candidate"
    fi
  fi
done

# A terminal or renderer crash can remove the recorded pnpm leader while the
# Electron main process and Vite server remain healthy. The native executable
# path is a stronger ownership witness than the mutable process title: adopt
# only an Electron binary physically rooted in the dedicated launch worktree.
# Foreign OpenAgents Dev builds still fail closed below.
if [[ -z "$managed_pid" && -n "$owned_unmanaged_pid" ]]; then
  recovered_pgid="$(/bin/ps -o pgid= -p "$owned_unmanaged_pid" | tr -d '[:space:]')"
  recovered_start="$(/bin/ps -o lstart= -p "$owned_unmanaged_pid" | sed -e 's/^ *//' -e 's/ *$//')"
  if [[ -z "$recovered_pgid" || "$recovered_pgid" != <-> || -z "$recovered_start" ]]; then
    echo "oa-dev: launcher-owned OpenAgents Dev process disappeared during recovery; retry" >&2
    exit 75
  fi
  if [[ -n "$recorded_orphan_pgid" && "$recovered_pgid" != "$recorded_orphan_pgid" ]]; then
    echo "oa-dev: recorded and executable process-group ownership disagree; refusing ambiguous recovery" >&2
    exit 1
  fi
  if /usr/bin/nc -z 127.0.0.1 5734 >/dev/null 2>&1; then
    recovered_head="$(git -C "$launch_repo" rev-parse HEAD 2>/dev/null)" || exit 1
    mkdir -p "$restart_root" && chmod 700 "$restart_root"
    recovered_token="$(node -e 'process.stdout.write(require("node:crypto").randomUUID())')"
    record_generation "$owned_unmanaged_pid" "$recovered_pgid" "$recovered_start" "$recovered_head" "$recovered_token" || exit 1
    managed_pid="$owned_unmanaged_pid"
    managed_pgid="$recovered_pgid"
    existing_pid="$owned_unmanaged_pid"
    echo "oa-dev: recovered launcher ownership for OpenAgents Dev process $owned_unmanaged_pid"
  else
    echo "oa-dev: renderer port 5734 is not ready; stopping the stale launcher-owned process group"
    /bin/kill -TERM -- "-$recovered_pgid" 2>/dev/null || true
    for _ in {1..100}; do
      /bin/ps -axo pgid= | tr -d ' ' | grep -qx "$recovered_pgid" || break
      sleep 0.1
    done
    if /bin/ps -axo pgid= | tr -d ' ' | grep -qx "$recovered_pgid"; then
      /bin/kill -KILL -- "-$recovered_pgid" 2>/dev/null || true
    fi
    for _ in {1..50}; do
      /bin/ps -axo pgid= | tr -d ' ' | grep -qx "$recovered_pgid" || break
      sleep 0.1
    done
    if /bin/ps -axo pgid= | tr -d ' ' | grep -qx "$recovered_pgid"; then
      echo "oa-dev: stale launcher-owned process group did not stop; launch worktree preserved" >&2
      exit 1
    fi
    rm -f "$generation_path"
    recorded_orphan_pgid=""
  fi
fi
if [[ -z "$managed_pid" && -n "$recorded_orphan_pgid" ]]; then
  echo "oa-dev: a recorded dev process group survived without a verifiable launcher-owned app; refusing to mutate the launch worktree" >&2
  exit 1
fi
if [[ -z "$managed_pid" && -n "$blocking_unmanaged_pid" ]]; then
  echo "oa-dev: an unmanaged OpenAgents Dev process exists; refusing to mutate the launch worktree" >&2
  exit 1
fi
if [[ -z "$managed_pid" ]] && /usr/bin/nc -z 127.0.0.1 5734 >/dev/null 2>&1; then
  echo "oa-dev: renderer port 5734 is occupied without a valid managed generation; refusing to mutate the launch worktree" >&2
  exit 1
fi
if $restart_requested && [[ -n "$managed_pid" ]]; then
  if [[ ! -e "$launch_repo/.git" ]]; then
    echo "oa-dev: cannot supervise restart because the managed launch worktree is missing" >&2
    exit 1
  fi
  target_sha="$(git -C "$source_repo" rev-parse origin/main)" || exit 1
  old_sha="$(git -C "$launch_repo" rev-parse HEAD 2>/dev/null)" || old_sha="unknown"
  old_pgid="$managed_pgid"
  [[ -n "$existing_pid" ]] || existing_pid="$managed_pid"
  if [[ -z "$old_pgid" || "$old_pgid" != <-> ]]; then
    echo "oa-dev: could not identify the running OpenAgents Dev process group" >&2
    exit 1
  fi
  lock_dir="$restart_root/active.lock"
  mkdir -p "$restart_root" || exit 1
  chmod 700 "$restart_root" || exit 1
  request_ref="restart-$(date -u +%Y%m%dT%H%M%SZ)-$$"
  receipt_path="$restart_root/$request_ref.json"
  log_path="$restart_root/$request_ref.log"
  supervisor_path="$restart_root/$request_ref-supervisor.mjs"
  label="com.openagents.desktop.dev-restart.$$.${target_sha[1,10]}"
  lock_token="$(node -e 'process.stdout.write(require("node:crypto").randomUUID())')"
  candidate_lock="$restart_root/.active.lock.$$.${lock_token}"
  mkdir "$candidate_lock" || exit 1
  printf '%s\n' "$receipt_path" > "$candidate_lock/receipt"
  printf '%s\n' "$$" > "$candidate_lock/owner-pid"
  printf '%s\n' "$label" > "$candidate_lock/launchd-label"
  printf '%s\n' "$lock_token" > "$candidate_lock/token"
  chmod 600 "$candidate_lock"/*
  if ! node -e 'require("node:fs").renameSync(process.argv[1], process.argv[2])' "$candidate_lock" "$lock_dir" 2>/dev/null; then
    active_receipt="$(cat "$lock_dir/receipt" 2>/dev/null)"
    active_owner_pid="$(cat "$lock_dir/owner-pid" 2>/dev/null)"
    active_label="$(cat "$lock_dir/launchd-label" 2>/dev/null)"
    active_coordinator_pid="$(node -e 'try { process.stdout.write(String(JSON.parse(require("node:fs").readFileSync(process.argv[1], "utf8")).coordinatorPid ?? "")) } catch {}' "$active_receipt")"
    restart_active=false
    if [[ -n "$active_owner_pid" ]] && kill -0 "$active_owner_pid" 2>/dev/null; then restart_active=true; fi
    if [[ -n "$active_coordinator_pid" ]] && kill -0 "$active_coordinator_pid" 2>/dev/null; then restart_active=true; fi
    if [[ -n "$active_label" ]] && /bin/launchctl print "gui/$UID/$active_label" >/dev/null 2>&1; then restart_active=true; fi
    if $restart_active; then
      rm -rf "$candidate_lock"
      echo "oa-dev: a supervised restart is already active${active_receipt:+; receipt: $active_receipt}" >&2
      exit 75
    fi
    echo "oa-dev: recovering an abandoned restart lock${active_receipt:+; prior receipt: $active_receipt}"
    lock_age="$(node -e 'const fs=require("node:fs"); try { process.stdout.write(String(Date.now()-fs.statSync(process.argv[1]).mtimeMs)) } catch { process.stdout.write("0") }' "$lock_dir")"
    if (( lock_age < 30000 )); then
      rm -rf "$candidate_lock"
      echo "oa-dev: restart lock is still initializing; retry" >&2
      exit 75
    fi
    rm -rf "$lock_dir"
    if ! node -e 'require("node:fs").renameSync(process.argv[1], process.argv[2])' "$candidate_lock" "$lock_dir" 2>/dev/null; then
      rm -rf "$candidate_lock"
      echo "oa-dev: restart lock recovery raced another request; retry" >&2
      exit 75
    fi
  fi
  if ! git -C "$source_repo" show "$target_sha:apps/openagents-desktop/scripts/oa-dev-supervisor.mjs" > "$supervisor_path"; then
    rm -rf "$lock_dir" "$supervisor_path"
    echo "oa-dev: target commit does not contain the restart supervisor" >&2
    exit 1
  fi
  chmod 500 "$supervisor_path"
  requested_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  pnpm_path="$(command -v pnpm)"
  if [[ -z "$pnpm_path" ]]; then
    rm -rf "$lock_dir" "$supervisor_path"
    echo "oa-dev: pnpm is required" >&2
    exit 1
  fi
  config_json="$(node -e '
    const value = {
      requestRef: process.argv[1], requestedAt: process.argv[2], oldCommit: process.argv[3],
      targetSha: process.argv[4], oldAppPid: Number(process.argv[5]), oldProcessGroupId: Number(process.argv[6]),
      sourceRepo: process.argv[7], launchRepo: process.argv[8], receiptPath: process.argv[9], lockDir: process.argv[10],
      logPath: process.argv[11], ownerLaunchCwd: process.argv[12], nodePath: process.argv[13], pnpmPath: process.argv[14],
      lockToken: process.argv[15], generationPath: process.argv[16], rendererPort: 5734,
      graceMs: 15000, quitTimeoutMs: 20000, groupTerminateTimeoutMs: 5000, forceQuitTimeoutMs: 5000,
      portReleaseTimeoutMs: 10000, readinessTimeoutMs: 60000,
    };
    process.stdout.write(Buffer.from(JSON.stringify(value)).toString("base64url"));
  ' "$request_ref" "$requested_at" "$old_sha" "$target_sha" "$existing_pid" "$old_pgid" "$source_repo" "$launch_repo" "$receipt_path" "$lock_dir" "$log_path" "$owner_launch_cwd" "$node24_bin/node" "$pnpm_path" "$lock_token" "$generation_path")" || {
    rm -rf "$lock_dir" "$supervisor_path"
    exit 1
  }
  if ! node -e '
    const fs = require("node:fs"); const path = require("node:path");
    const receiptPath = process.argv[1]; const next = `${receiptPath}.next-${process.pid}`;
    const document = {
      schemaVersion: "openagents.desktop.dev_restart_receipt.v1", coordinatorVersion: 1, state: "scheduled",
      requestRef: process.argv[2], requestedAt: process.argv[3], oldCommit: process.argv[4], targetCommit: process.argv[5],
      oldAppPid: Number(process.argv[6]), oldProcessGroupId: Number(process.argv[7]), receiptPath,
    };
    fs.writeFileSync(next, `${JSON.stringify(document, null, 2)}\n`, { mode: 0o600 });
    const file = fs.openSync(next, "r"); fs.fsyncSync(file); fs.closeSync(file); fs.renameSync(next, receiptPath);
    const parent = fs.openSync(path.dirname(receiptPath), "r"); fs.fsyncSync(parent); fs.closeSync(parent);
  ' "$receipt_path" "$request_ref" "$requested_at" "$old_sha" "$target_sha" "$existing_pid" "$old_pgid"; then
    rm -rf "$lock_dir" "$supervisor_path"
    exit 1
  fi
  mark_restart_failed() {
    node -e '
      const fs = require("node:fs"); const path = require("node:path"); const receiptPath = process.argv[1];
      const document = { ...JSON.parse(fs.readFileSync(receiptPath, "utf8")), state: "failed", ready: false,
        failedAt: new Date().toISOString(), error: process.argv[2], recoveryCommand: "oa-dev" };
      const next = `${receiptPath}.next-${process.pid}`; fs.writeFileSync(next, `${JSON.stringify(document, null, 2)}\n`, { mode: 0o600 });
      const file = fs.openSync(next, "r"); fs.fsyncSync(file); fs.closeSync(file); fs.renameSync(next, receiptPath);
      const parent = fs.openSync(path.dirname(receiptPath), "r"); fs.fsyncSync(parent); fs.closeSync(parent);
    ' "$receipt_path" "$1"
  }
  if ! /bin/launchctl submit -l "$label" -o "$log_path" -e "$log_path" -- \
      /usr/bin/env "PATH=$PATH" "$node24_bin/node" "$supervisor_path" supervise "$config_json"; then
    mark_restart_failed "launchd refused restart handoff; the running app was preserved"
    rm -rf "$lock_dir" "$supervisor_path"
    echo "oa-dev: launchd refused restart handoff; the running app was preserved" >&2
    exit 1
  fi
  handoff_owned=false
  for _ in {1..100}; do
    receipt_state="$(node -e 'try { process.stdout.write(JSON.parse(require("node:fs").readFileSync(process.argv[1], "utf8")).state ?? "") } catch {}' "$receipt_path")"
    if [[ "$receipt_state" == "handoff_owned" || "$receipt_state" == "synchronizing" || "$receipt_state" == "ready" ]]; then
      handoff_owned=true
      break
    fi
    sleep 0.1
  done
  if ! $handoff_owned; then
    /bin/launchctl remove "$label" >/dev/null 2>&1 || true
    mark_restart_failed "launchd did not acknowledge restart ownership; the running app was preserved"
    rm -rf "$lock_dir"
    echo "oa-dev: launchd did not acknowledge restart ownership; the running app was preserved" >&2
    echo "oa-dev: inspect $receipt_path" >&2
    exit 1
  fi
  echo "oa-dev: supervised restart accepted by launchd"
  echo "oa-dev: current app PID $existing_pid will exit after a 15s handoff grace"
  echo "oa-dev: target ${target_sha[1,10]} receipt $receipt_path"
  exit 0
fi
if [[ -n "$managed_pid" ]]; then
  echo "oa-dev: OpenAgents Dev is already running as process $managed_pid"
  if [[ -e "$launch_repo/.git" ]]; then
    launch_head="$(git -C "$launch_repo" rev-parse HEAD 2>/dev/null)"
    origin_head="$(git -C "$source_repo" rev-parse origin/main)"
    if [[ -n "$launch_head" && "$launch_head" != "$origin_head" ]]; then
      behind_count="$(git -C "$source_repo" rev-list --count "$launch_head..$origin_head" 2>/dev/null)"
      echo "oa-dev: running stable preview is ${behind_count:-unknown} commit(s) behind origin/main; restart OpenAgents Dev to update"
    else
      echo "oa-dev: running stable preview matches origin/main at ${origin_head[1,10]}"
    fi
  else
    echo "oa-dev: running stable preview revision is unavailable; restart OpenAgents Dev to synchronize"
  fi
  if [[ -n "$existing_pid" ]] && ! /usr/bin/osascript -e "tell application \"System Events\" to set frontmost of first application process whose unix id is $existing_pid to true" >/dev/null 2>&1; then
    echo "oa-dev: could not activate the existing OpenAgents Dev window" >&2
    exit 1
  fi
  exit 0
fi

if [[ ! -e "$launch_repo/.git" ]]; then
  if [[ -e "$launch_repo" ]]; then
    echo "oa-dev: $launch_repo exists but is not the managed launch worktree" >&2
    exit 1
  fi
  echo "oa-dev: creating isolated launch worktree"
  git -C "$source_repo" worktree add --detach "$launch_repo" origin/main || exit 1
fi

# This worktree is launcher-owned and never an implementation home. Repairing
# it is safe and makes stale mode bits or interrupted generated output unable
# to brick the owner's dev command.
if [[ -n "$(git -C "$launch_repo" status --porcelain)" ]]; then
  echo "oa-dev: repairing managed launch worktree"
  git -C "$launch_repo" reset --hard --quiet HEAD || exit 1
  git -C "$launch_repo" clean -fdq || exit 1
fi
git -C "$launch_repo" switch --detach --force --quiet origin/main || exit 1

launch_head="$(git -C "$launch_repo" rev-parse HEAD)"
origin_head="$(git -C "$source_repo" rev-parse origin/main)"
if [[ "$launch_head" != "$origin_head" ]]; then
  echo "oa-dev: isolated launch worktree could not synchronize to origin/main" >&2
  exit 1
fi
echo "oa-dev: launching clean origin/main at ${launch_head[1,10]}"

export OPENAGENTS_DESKTOP_LAUNCH_CWD="$owner_launch_cwd"
cd "$launch_repo" || exit 1
lock_ref="$(git rev-parse HEAD:pnpm-lock.yaml 2>/dev/null)"
deps_key="${lock_ref}:$(node --version):$(pnpm --version)"
deps_marker="$launch_repo/node_modules/.oa-deps-key"
electron_package="$launch_repo/apps/openagents-desktop/node_modules/electron"
electron_app="$electron_package/dist/Electron.app"

if [[ ! -d node_modules || ! -f "$deps_marker" || "$(<"$deps_marker")" != "$deps_key" ]]; then
  echo "oa-dev: syncing pnpm dependencies"
  # Dependency synchronization only needs to materialize the lockfile graph.
  # Running workspace lifecycle scripts here makes an ordinary dev launch
  # execute every package's prepare hook and can kill the launcher before the
  # desktop app starts. Electron's required postinstall is verified and
  # repaired explicitly below.
  pnpm install --frozen-lockfile --ignore-scripts || exit 1
  printf '%s\n' "$deps_key" >| "$deps_marker"
fi
if [[ ! -x "$electron_app/Contents/MacOS/Electron" ||
      ! -e "$electron_app/Contents/Frameworks/Electron Framework.framework/Electron Framework" ]]; then
  echo "oa-dev: repairing Electron runtime"
  rm -rf "$electron_package/dist"
  node "$electron_package/install.js" || exit 1
fi
if [[ ! -x "$electron_app/Contents/MacOS/Electron" ||
      ! -e "$electron_app/Contents/Frameworks/Electron Framework.framework/Electron Framework" ]]; then
  echo "oa-dev: Electron runtime failed integrity verification" >&2
  exit 1
fi

mkdir -p "$restart_root" && chmod 700 "$restart_root"
launch_pgid="$(/bin/ps -o pgid= -p $$ | tr -d '[:space:]')"
launch_start="$(/bin/ps -o lstart= -p $$ | sed -e 's/^ *//' -e 's/ *$//')"
generation_token="$(node -e 'process.stdout.write(require("node:crypto").randomUUID())')"
record_generation "$$" "$launch_pgid" "$launch_start" "$launch_head" "$generation_token" || exit 1

exec pnpm --dir apps/openagents-desktop dev "$@"
