{
  "expo": {
    "name": "OpenAgents",
    "slug": "openagents-mobile",
    "scheme": "openagents",
    "version": "0.5.2",
    "icon": "./assets/images/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#05070d",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#05070d",
      "resizeMode": "contain"
    },
    "ios": {
      "appleTeamId": "HQWSG26L43",
      "bundleIdentifier": "com.openagents.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "122"
    },
    "android": {
      "package": "com.openagents.app"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://updates.openagents.com/openagents-mobile/manifest",
      "requestHeaders": {
        "expo-channel-name": "openagents-production"
      }
    },
    "plugins": [
      "expo-notifications",
      "expo-updates",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ]
    ]
  }
}
