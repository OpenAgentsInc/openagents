---
import {
  GITHUB_REPOSITORY_URL,
  PRODUCT_PROMISES_URL,
} from '../lib/site'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'OpenAgents Desktop',
  description =
    'A local-first desktop workroom for durable, reviewable Codex work.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://openagents.com/astro" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <nav class="nav container" aria-label="Primary navigation">
          <a class="brand" href="/astro" aria-label="OpenAgents Desktop home">
            <span class="brand-mark" aria-hidden="true">
              <span></span><span></span><span></span>
            </span>
            <span>OpenAgents</span>
          </a>

          <div class="nav-status" aria-label="Product status">
            <span class="status-light" aria-hidden="true"></span>
            Desktop MVP
          </div>

          <div class="nav-links">
            <a href={PRODUCT_PROMISES_URL}>Promises</a>
            <a href={GITHUB_REPOSITORY_URL} target="_blank" rel="noreferrer">
              Source <span aria-hidden="true">↗</span>
            </a>
          </div>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container footer-inner">
          <p>OpenAgents Desktop · local-first Codex workroom</p>
          <div class="footer-links">
            <a href={PRODUCT_PROMISES_URL}>Product promises</a>
            <a href={GITHUB_REPOSITORY_URL} target="_blank" rel="noreferrer">
              GitHub
            </a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --void: #000000;
    --surface: #010102;
    --surface-muted: #030711;
    --surface-raised: #0b1322;
    --border: #17315f;
    --border-subtle: #101b30;
    --energy: #3a7bff;
    --energy-cyan: #4fd0ff;
    --energy-soft: #8fb6ff;
    --text: #f1efe8;
    --text-muted: rgb(241 239 232 / 0.72);
    --text-faint: rgb(241 239 232 / 0.48);
    --success: #00c853;
    --font-sans: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-mono: "Berkeley Mono", "SFMono-Regular", "Cascadia Code", Menlo, monospace;
    --container: 76rem;
  }

  * {
    box-sizing: border-box;
  }

  html {
    min-width: 320px;
    background: var(--void);
    scroll-behavior: smooth;
  }

  body {
    min-width: 320px;
    min-height: 100vh;
    margin: 0;
    background: var(--void);
    color: var(--text);
    font-family: var(--font-sans);
    font-synthesis: none;
    line-height: 1.55;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  a {
    -webkit-tap-highlight-color: transparent;
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1,
  h2,
  h3 {
    text-wrap: balance;
  }

  p {
    text-wrap: pretty;
  }

  :focus-visible {
    outline: 2px solid var(--energy-cyan);
    outline-offset: 4px;
  }

  .container {
    width: min(100% - 2rem, var(--container));
    margin-inline: auto;
  }

  .site-shell {
    min-height: 100vh;
    overflow: hidden;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgb(0 0 0 / 0.94);
    border-bottom: 1px solid var(--border-subtle);
  }

  .nav {
    min-height: 4rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.5rem;
  }

  .brand {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.94rem;
    font-weight: 650;
    letter-spacing: -0.015em;
  }

  .brand-mark {
    width: 1.1rem;
    height: 1.1rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: end;
    gap: 2px;
  }

  .brand-mark span {
    display: block;
    background: var(--energy);
  }

  .brand-mark span:nth-child(1) { height: 45%; }
  .brand-mark span:nth-child(2) { height: 100%; background: var(--energy-cyan); }
  .brand-mark span:nth-child(3) { height: 68%; }

  .nav-status {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .status-light {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--success);
  }

  .nav-links,
  .footer-links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.25rem;
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .nav-links a,
  .footer-links a {
    transition: color 180ms ease-out;
  }

  .nav-links a:hover,
  .footer-links a:hover {
    color: var(--energy-cyan);
  }

  .site-footer {
    border-top: 1px solid var(--border-subtle);
  }

  .footer-inner {
    min-height: 6rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  @media (max-width: 700px) {
    .nav {
      grid-template-columns: 1fr auto;
    }

    .nav-status {
      display: none;
    }

    .nav-links a:first-child {
      display: none;
    }

    .footer-inner {
      padding-block: 1.5rem;
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
