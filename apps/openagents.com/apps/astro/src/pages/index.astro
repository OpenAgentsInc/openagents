---
import Layout from '../layouts/Layout.astro'
import {
  DOCS_URL,
  GITHUB_REPOSITORY_URL,
  PRODUCT_BOUNDARIES,
  PRODUCT_SPEC_URL,
} from '../lib/site'

const workroomSteps = [
  {
    title: 'Start where you left off',
    body: 'Recent sessions appear before transcripts hydrate, with stable identity across reloads and restarts.',
  },
  {
    title: 'Keep the turn legible',
    body: 'Conversation, plans, tools, changes, decisions, and blockers stay in one causal timeline.',
  },
  {
    title: 'Review the exact change',
    body: 'Repository status and diffs are bounded to the active work context and remain read-only.',
  },
  {
    title: 'Return without guessing',
    body: 'Interrupted work reconciles explicitly. Nothing silently reruns or substitutes another session.',
  },
] as const
---

<Layout>
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="hero-kicker">Codex, made durable.</p>
        <h1>A serious place<br />for serious agent work.</h1>
        <p class="hero-summary">
          OpenAgents Desktop is a local-first workroom around your ordinary
          Codex session—built to find work, follow the turn, review changes,
          and resume without losing the thread.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href={PRODUCT_SPEC_URL} target="_blank" rel="noreferrer">
            Read the product spec <span aria-hidden="true">↗</span>
          </a>
          <a class="button button-secondary" href={DOCS_URL}>
            Read the docs
          </a>
        </div>
        <p class="release-note">
          macOS candidate · public download follows release approval
        </p>
      </div>

      <div class="hero-signal" aria-hidden="true">
        <span>session.open</span>
        <span>turn.streaming</span>
        <span>change.reviewable</span>
        <span>restart.reconciled</span>
      </div>
    </div>
  </section>

  <section class="preview-section" aria-labelledby="preview-title">
    <div class="container">
      <div class="section-heading preview-heading">
        <div>
          <h2 id="preview-title">Conversation first.</h2>
          <p>The active turn stays central. Navigation and review stay close, but quiet.</p>
        </div>
        <span>Desktop preview</span>
      </div>

      <figure class="workbench" data-replace-with-screenshot>
        <div class="window-bar">
          <div class="window-dots" aria-hidden="true"><i></i><i></i><i></i></div>
          <span>OpenAgents</span>
          <span class="window-state"><i></i> Codex connected</span>
        </div>

        <div class="workbench-body">
          <aside class="session-rail">
            <button class="new-session" type="button">＋ New chat</button>
            <div class="session-group">
              <span>Today</span>
              <div class="session active">
                <strong>Astro landing surface</strong>
                <small>Streaming · now</small>
              </div>
              <div class="session">
                <strong>Release acceptance</strong>
                <small>Complete · 42m</small>
              </div>
              <div class="session">
                <strong>Composer recovery</strong>
                <small>Blocked · 2h</small>
              </div>
            </div>
          </aside>

          <div class="conversation">
            <header class="conversation-header">
              <div>
                <strong>Astro landing surface</strong>
                <span>openagents · main</span>
              </div>
              <button type="button">Review changes <b>4</b></button>
            </header>

            <div class="timeline">
              <div class="message user-message">
                Build the new landing page as a minimal Astro site and keep the
                route isolated until homepage cutover.
              </div>
              <div class="message agent-message">
                <span class="agent-name">Codex</span>
                <p>
                  I traced the existing deployment boundary and the T3 marketing
                  package. I’m adding one static Astro app, a bounded Cloud Run
                  mount, and a replaceable product-preview seam.
                </p>
              </div>
              <div class="tool-row">
                <span class="tool-state"></span>
                <strong>Working</strong>
                <span>apps/openagents.com/apps/astro</span>
                <time>00:38</time>
              </div>
              <div class="change-row">
                <span>＋</span>
                <div>
                  <strong>4 files changed</strong>
                  <small>Astro app · Cloud Run mount · route tests</small>
                </div>
                <button type="button">Open review</button>
              </div>
            </div>

            <div class="composer">
              <span>Steer the current turn…</span>
              <div class="composer-footer">
                <span>openagents / main</span>
                <button type="button" aria-label="Stop current turn">■</button>
              </div>
            </div>
          </div>
        </div>
        <figcaption>
          Product frame for layout validation. Replace this figure with the current Desktop screenshot before homepage cutover.
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="system-section" aria-labelledby="system-title">
    <div class="container system-layout">
      <div class="system-intro">
        <h2 id="system-title">Codex stays the engine.<br />OpenAgents keeps the work legible.</h2>
        <p>
          The workroom adds durable structure around the loop you already use.
          It does not replace your model account, invent another thread store,
          or turn review into hidden mutation.
        </p>
      </div>

      <ol class="workroom-steps">
        {workroomSteps.map((step, index) => (
          <li>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="boundary-section" aria-label="Product boundaries">
    <div class="container boundary-strip">
      {PRODUCT_BOUNDARIES.map((boundary) => (
        <p><span aria-hidden="true">✓</span>{boundary}</p>
      ))}
    </div>
  </section>

  <section class="closing-section">
    <div class="container closing-layout">
      <div>
        <p>Open source. Local first. Evidence backed.</p>
        <h2>The work should survive the window.</h2>
      </div>
      <a class="source-link" href={GITHUB_REPOSITORY_URL} target="_blank" rel="noreferrer">
        Explore the source <span aria-hidden="true">↗</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    border-bottom: 1px solid var(--border-subtle);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 50%;
    width: 1px;
    background: var(--border-subtle);
  }

  .hero-inner {
    min-height: min(47rem, calc(100vh - 4rem));
    display: grid;
    grid-template-columns: minmax(0, 1fr) 14rem;
    align-items: center;
    gap: clamp(3rem, 8vw, 8rem);
    padding-block: clamp(5rem, 11vw, 9rem);
  }

  .hero-copy {
    max-width: 54rem;
  }

  .hero-kicker {
    margin-bottom: 1.5rem;
    color: var(--energy-cyan);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  h1 {
    max-width: 13ch;
    font-size: clamp(3.25rem, 7.2vw, 6rem);
    font-weight: 560;
    letter-spacing: -0.04em;
    line-height: 0.98;
  }

  .hero-summary {
    max-width: 43rem;
    margin-top: 2rem;
    color: var(--text-muted);
    font-size: clamp(1.02rem, 1.8vw, 1.25rem);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.25rem;
  }

  .button {
    min-height: 2.9rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 0.75rem 1rem;
    border-radius: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    transition: background 180ms ease-out, border-color 180ms ease-out, color 180ms ease-out;
  }

  .button-primary {
    background: var(--energy);
    color: white;
  }

  .button-primary:hover {
    background: #2769ec;
  }

  .button-secondary {
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .button-secondary:hover {
    border-color: var(--energy);
    color: var(--text);
  }

  .release-note {
    margin-top: 1rem;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .hero-signal {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.35rem;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.69rem;
  }

  .hero-signal span {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-signal span::before {
    content: '';
    width: 2rem;
    height: 1px;
    background: var(--energy);
  }

  .preview-section {
    padding-block: clamp(5rem, 10vw, 9rem);
    background: var(--surface-muted);
    border-bottom: 1px solid var(--border-subtle);
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
  }

  .section-heading h2,
  .system-intro h2,
  .closing-layout h2 {
    font-size: clamp(2rem, 4vw, 3.8rem);
    font-weight: 540;
    letter-spacing: -0.035em;
    line-height: 1.05;
  }

  .section-heading p,
  .system-intro > p {
    max-width: 39rem;
    margin-top: 0.85rem;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .section-heading > span {
    color: var(--energy-cyan);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }

  .workbench {
    margin: 2.5rem 0 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    overflow: hidden;
  }

  .window-bar {
    min-height: 2.8rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding-inline: 1rem;
    border-bottom: 1px solid var(--border-subtle);
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.64rem;
  }

  .window-dots {
    display: flex;
    gap: 0.35rem;
  }

  .window-dots i {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: #24314a;
  }

  .window-state {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.45rem;
  }

  .window-state i {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 50%;
    background: var(--success);
  }

  .workbench-body {
    min-height: 36rem;
    display: grid;
    grid-template-columns: 15rem minmax(0, 1fr);
  }

  .session-rail {
    padding: 1rem;
    background: #02040a;
    border-right: 1px solid var(--border-subtle);
  }

  .new-session,
  .conversation-header button,
  .change-row button,
  .composer button {
    color: inherit;
    font: inherit;
  }

  .new-session {
    width: 100%;
    min-height: 2.4rem;
    border: 1px solid var(--border);
    border-radius: 0.3rem;
    background: var(--surface-raised);
    color: var(--energy-soft);
    text-align: left;
  }

  .session-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-top: 1.6rem;
  }

  .session-group > span {
    margin: 0 0 0.35rem 0.45rem;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.62rem;
  }

  .session {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.7rem 0.75rem;
    border-radius: 0.3rem;
    color: var(--text-muted);
  }

  .session.active {
    background: var(--surface-raised);
    color: var(--text);
  }

  .session strong {
    overflow: hidden;
    font-size: 0.74rem;
    font-weight: 540;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .session small {
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.57rem;
  }

  .conversation {
    min-width: 0;
    display: grid;
    grid-template-rows: auto 1fr auto;
  }

  .conversation-header {
    min-height: 4.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 1.25rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .conversation-header div {
    display: flex;
    flex-direction: column;
  }

  .conversation-header strong {
    font-size: 0.82rem;
    font-weight: 560;
  }

  .conversation-header span {
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.6rem;
  }

  .conversation-header button,
  .change-row button {
    border: 1px solid var(--border-subtle);
    border-radius: 0.3rem;
    background: transparent;
    color: var(--text-muted);
    font-size: 0.65rem;
  }

  .conversation-header button b {
    margin-left: 0.3rem;
    color: var(--energy-cyan);
  }

  .timeline {
    width: min(100% - 2rem, 47rem);
    margin-inline: auto;
    padding: 2.2rem 0 3rem;
  }

  .message {
    max-width: 80%;
    font-size: 0.79rem;
    line-height: 1.65;
  }

  .user-message {
    margin-left: auto;
    padding: 0.75rem 0.9rem;
    background: #0b1930;
    border-radius: 0.55rem 0.55rem 0.1rem 0.55rem;
  }

  .agent-message {
    margin-top: 1.6rem;
  }

  .agent-name {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--energy-cyan);
    font-family: var(--font-mono);
    font-size: 0.61rem;
  }

  .agent-message p {
    color: var(--text-muted);
  }

  .tool-row,
  .change-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-top: 1.35rem;
    padding: 0.65rem 0;
    border-block: 1px solid var(--border-subtle);
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.58rem;
  }

  .tool-row strong {
    color: var(--text-muted);
  }

  .tool-row time {
    margin-left: auto;
  }

  .tool-state {
    width: 0.45rem;
    height: 0.45rem;
    border: 1px solid var(--energy-cyan);
    border-radius: 50%;
  }

  .change-row {
    margin-top: 0.8rem;
    padding: 0.8rem;
    background: #030812;
    border: 1px solid var(--border-subtle);
    border-radius: 0.35rem;
  }

  .change-row > span {
    color: var(--success);
    font-size: 1rem;
  }

  .change-row div {
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  .change-row strong {
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 0.7rem;
  }

  .change-row button {
    padding: 0.45rem 0.6rem;
  }

  .composer {
    width: min(100% - 2rem, 47rem);
    margin: 0 auto 1.35rem;
    padding: 0.9rem;
    border: 1px solid var(--border);
    border-radius: 0.45rem;
    background: #030812;
    color: var(--text-faint);
    font-size: 0.72rem;
  }

  .composer-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.56rem;
  }

  .composer button {
    width: 1.7rem;
    height: 1.7rem;
    border: 0;
    border-radius: 50%;
    background: var(--energy);
    color: white;
    font-size: 0.5rem;
  }

  figcaption {
    padding: 0.65rem 1rem;
    border-top: 1px solid var(--border-subtle);
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.61rem;
    text-align: center;
  }

  .system-section {
    padding-block: clamp(6rem, 12vw, 10rem);
    border-bottom: 1px solid var(--border-subtle);
  }

  .system-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(26rem, 1fr);
    gap: clamp(4rem, 10vw, 9rem);
  }

  .workroom-steps {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--border);
  }

  .workroom-steps li {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1.25rem;
    padding-block: 1.5rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .workroom-steps li > span {
    color: var(--energy-cyan);
    font-family: var(--font-mono);
    font-size: 0.67rem;
  }

  .workroom-steps h3 {
    font-size: 0.95rem;
    font-weight: 560;
  }

  .workroom-steps p {
    max-width: 38rem;
    margin-top: 0.45rem;
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.7;
  }

  .boundary-section {
    border-bottom: 1px solid var(--border-subtle);
    background: var(--surface-muted);
  }

  .boundary-strip {
    min-height: 6.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: stretch;
  }

  .boundary-strip p {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 1.5rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    border-right: 1px solid var(--border-subtle);
  }

  .boundary-strip p:first-child {
    border-left: 1px solid var(--border-subtle);
  }

  .boundary-strip span {
    color: var(--success);
  }

  .closing-section {
    padding-block: clamp(6rem, 12vw, 10rem);
  }

  .closing-layout {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 3rem;
  }

  .closing-layout p {
    margin-bottom: 1rem;
    color: var(--energy-cyan);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .source-link {
    flex: 0 0 auto;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--energy);
    color: var(--energy-soft);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  @media (max-width: 900px) {
    .hero::before,
    .hero-signal {
      display: none;
    }

    .hero-inner {
      min-height: auto;
      grid-template-columns: 1fr;
    }

    .workbench-body {
      grid-template-columns: 11.5rem minmax(0, 1fr);
    }

    .system-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    h1 {
      font-size: clamp(3rem, 15vw, 4.35rem);
    }

    .section-heading,
    .closing-layout {
      align-items: flex-start;
      flex-direction: column;
    }

    .workbench-body {
      min-height: 34rem;
      grid-template-columns: 1fr;
    }

    .session-rail {
      display: none;
    }

    .window-bar {
      grid-template-columns: 1fr auto;
    }

    .window-bar > span:nth-child(2) {
      display: none;
    }

    .timeline {
      padding-top: 1.5rem;
    }

    .message {
      max-width: 92%;
    }

    .boundary-strip {
      grid-template-columns: 1fr;
    }

    .boundary-strip p,
    .boundary-strip p:first-child {
      border-inline: 1px solid var(--border-subtle);
      border-bottom: 1px solid var(--border-subtle);
    }

    .boundary-strip p:last-child {
      border-bottom: 0;
    }
  }
</style>
