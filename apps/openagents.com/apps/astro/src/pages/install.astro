---
import Layout from '../layouts/Layout.astro'
import { DOCS_URL, MAC_RELEASE } from '../lib/site'
---

<Layout
  title="Install OpenAgents for Mac"
  description="Download the latest OpenAgents Desktop release candidate for Apple-silicon Macs."
  canonicalUrl="https://openagents.com/install"
>
  <section class="install-hero">
    <div class="container install-layout">
      <div class="install-copy">
        <p class="eyebrow">OpenAgents Desktop</p>
        <h1>Bring your Codex work<br /> into one durable place.</h1>
        <p class="summary">
          Download the latest OpenAgents Desktop candidate for Mac. It uses
          your ordinary Codex session and keeps your work local, legible, and
          ready to resume.
        </p>

        <div class="download-row">
          <a
            class="download-button"
            href={MAC_RELEASE.downloadUrl}
            rel="noreferrer"
          >
            <span>Download for Mac</span>
            <small>{MAC_RELEASE.version} · {MAC_RELEASE.size}</small>
          </a>
          <p>{MAC_RELEASE.architecture}<br />macOS disk image</p>
        </div>

        <p class="candidate-note">
          This is a release candidate for early use, not the stable release.
        </p>
      </div>

      <aside class="release-panel" aria-label="Release details">
        <p class="panel-label">Current candidate</p>
        <dl>
          <div>
            <dt>Version</dt>
            <dd>{MAC_RELEASE.version}</dd>
          </div>
          <div>
            <dt>Platform</dt>
            <dd>{MAC_RELEASE.platform}</dd>
          </div>
          <div>
            <dt>Chip</dt>
            <dd>{MAC_RELEASE.architecture}</dd>
          </div>
          <div>
            <dt>Package</dt>
            <dd>.dmg</dd>
          </div>
        </dl>
        <a href={MAC_RELEASE.releaseUrl} target="_blank" rel="noreferrer">
          View release notes <span aria-hidden="true">↗</span>
        </a>
      </aside>
    </div>
  </section>

  <section class="steps-section" aria-labelledby="steps-title">
    <div class="container steps-layout">
      <div>
        <p class="eyebrow">Install</p>
        <h2 id="steps-title">From download to workroom.</h2>
      </div>
      <ol>
        <li>
          <span>01</span>
          <div>
            <h3>Open the disk image</h3>
            <p>Double-click the downloaded DMG in Finder.</p>
          </div>
        </li>
        <li>
          <span>02</span>
          <div>
            <h3>Move OpenAgents to Applications</h3>
            <p>Drag the app into your Applications folder.</p>
          </div>
        </li>
        <li>
          <span>03</span>
          <div>
            <h3>Launch and start working</h3>
            <p>Open OpenAgents and continue with your existing Codex setup.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="help-section">
    <div class="container help-row">
      <p>Need the setup details or product boundaries?</p>
      <a href={DOCS_URL}>Read the docs <span aria-hidden="true">→</span></a>
    </div>
  </section>
</Layout>

<style>
  .install-hero {
    position: relative;
    border-bottom: 1px solid var(--border-subtle);
  }

  .install-hero::after {
    position: absolute;
    inset: 0 0 0 58%;
    z-index: -1;
    background:
      linear-gradient(90deg, rgb(5 7 13 / 0.2), var(--void)),
      repeating-linear-gradient(90deg, transparent 0 5rem, rgb(79 208 255 / 0.055) 5rem calc(5rem + 1px));
    content: '';
  }

  .install-layout {
    min-height: min(46rem, calc(100vh - 4rem));
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(17rem, 0.65fr);
    align-items: center;
    gap: clamp(4rem, 9vw, 9rem);
    padding-block: clamp(5rem, 11vw, 9rem);
  }

  .install-copy,
  .release-panel {
    min-width: 0;
  }

  .eyebrow,
  .panel-label {
    color: var(--energy-cyan);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
  }

  h1 {
    max-width: 15ch;
    margin-top: 1.35rem;
    font-size: clamp(3.25rem, 6.8vw, 6rem);
    font-weight: 560;
    letter-spacing: -0.045em;
    line-height: 0.98;
    overflow-wrap: anywhere;
  }

  .summary {
    max-width: 42rem;
    margin-top: 2rem;
    color: var(--text-muted);
    font-size: clamp(1.02rem, 1.8vw, 1.22rem);
    line-height: 1.7;
  }

  .download-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
    margin-top: 2.4rem;
  }

  .download-button {
    min-width: 15rem;
    min-height: 4.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.15rem;
    padding: 0.75rem 1.2rem;
    border-radius: 0.35rem;
    background: var(--energy);
    color: white;
    transition: background 180ms ease-out, transform 180ms ease-out;
  }

  .download-button:hover {
    background: #2769ec;
    transform: translateY(-1px);
  }

  .download-button span {
    font-size: 0.96rem;
    font-weight: 650;
  }

  .download-button small,
  .download-row > p,
  .candidate-note {
    font-family: var(--font-mono);
    font-size: 0.66rem;
  }

  .download-button small {
    color: rgb(255 255 255 / 0.72);
  }

  .download-row > p {
    color: var(--text-faint);
    line-height: 1.55;
  }

  .candidate-note {
    margin-top: 1rem;
    color: var(--text-faint);
  }

  .release-panel {
    padding: 1.5rem 0;
    border-block: 1px solid var(--border);
  }

  .release-panel dl {
    margin: 1.2rem 0 1.5rem;
  }

  .release-panel dl > div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.85rem;
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .release-panel dt {
    color: var(--text-faint);
  }

  .release-panel dd {
    margin: 0;
    color: var(--text-muted);
    text-align: right;
  }

  .release-panel > a {
    color: var(--energy-soft);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }

  .release-panel > a:hover,
  .help-row a:hover {
    color: var(--energy-cyan);
  }

  .steps-section {
    padding-block: clamp(5rem, 9vw, 8rem);
    background: var(--surface-muted);
    border-bottom: 1px solid var(--border-subtle);
  }

  .steps-layout {
    display: grid;
    grid-template-columns: minmax(14rem, 0.75fr) minmax(0, 1.25fr);
    gap: clamp(3rem, 8vw, 8rem);
  }

  h2 {
    max-width: 12ch;
    margin-top: 1rem;
    font-size: clamp(2.2rem, 4.2vw, 4rem);
    font-weight: 540;
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 1rem;
    padding-block: 1.5rem;
    border-top: 1px solid var(--border);
  }

  li > span {
    color: var(--energy-cyan);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  h3 {
    font-size: 1rem;
    font-weight: 620;
  }

  li p {
    margin-top: 0.45rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .help-section {
    padding-block: 2.2rem;
  }

  .help-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .help-row a {
    color: var(--energy-soft);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  @media (max-width: 760px) {
    .install-hero::after {
      display: none;
    }

    .install-layout,
    .steps-layout {
      grid-template-columns: 1fr;
    }

    .install-layout {
      gap: 4rem;
      padding-block: 4.5rem;
    }

    h1 {
      text-wrap: wrap;
    }

    h1 br {
      display: none;
    }

    .download-button {
      width: 100%;
    }

    .steps-layout {
      gap: 3rem;
    }

    .help-row {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
