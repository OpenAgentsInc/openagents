{
  "name": "@openagentsinc/openagents-com-start",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build --logLevel warn",
    "budget": "bun run build && bun run src/routes/-funnel-budget.ts",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "cf:typegen": "wrangler types"
  },
  "dependencies": {
    "@openagentsinc/effect-start": "workspace:*",
    "@openagentsinc/sync-worker": "workspace:*",
    "@tanstack/db": "0.6.14",
    "@tanstack/query-core": "5.101.0",
    "@tanstack/react-db": "0.1.92",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/react-start-client": "1.168.14",
    "effect": "4.0.0-beta.70",
    "lucide-react": "^1.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.42.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.13",
    "vitest": "^4.1.8",
    "wrangler": "^4.102.0"
  }
