{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./src/*"]
    },
    "types": ["node", "vite-plus-matchers", "vite/client", "openagents-platform"]
  },
  "include": ["scripts/**/*.ts", "src/**/*.ts", "src/**/*.tsx", "vite.config.ts"]
}
