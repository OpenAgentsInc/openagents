{
  "name": "@openagents/api-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "cd ../.. && bun run check:deploy && cd workers/api && wrangler d1 migrations apply openagents-autopilot --remote && cd ../.. && bun run build:web && cd workers/api && wrangler deploy",
    "smoke:cs336-a2:device-capability": "vitest run src/training-device-capability.test.ts src/training-run-window-routes.test.ts",
    "smoke:cs336-a3:isoflop": "vitest run src/training-scaling-sweep.test.ts src/training-run-window-routes.test.ts",
    "smoke:cs336-a4:data-refinery": "vitest run src/cs336-a4-data-refinery.test.ts src/training-verification.test.ts",
    "smoke:cs336-a1:no-spend": "vitest run src/cs336-a1-homework.test.ts src/training-verification.test.ts",
    "smoke:training-runs:public": "vitest run src/training-run-window-routes.test.ts src/training-run-window-authority.test.ts src/training-run-public-copy-gate.test.ts",
    "smoke:training-validator:no-spend": "vitest run src/training-validator-assignments.test.ts src/training-verification.test.ts",
    "smoke:autopilot-coder:no-spend": "vitest run src/autopilot-work-routes.test.ts -t \"no-spend Autopilot Coder end-to-end smoke\"",
    "smoke:autopilot-coder:paid": "vitest run src/autopilot-work-routes.test.ts -t \"paid Autopilot Coder end-to-end smoke\"",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cloudflare/containers": "0.3.7",
    "@effect/sql-d1": "4.0.0-beta.70",
    "@effect/sql-sqlite-do": "4.0.0-beta.70",
    "@liquid-js/qrcode-generator": "1.1.6",
    "@moneydevkit/api-contract": "0.1.36",
    "@openagents/nip90": "workspace:*",
    "@openagents/email-templates": "workspace:*",
    "@openagents/mullet-schema": "workspace:*",
    "@openagents/mullet-sim": "workspace:*",
    "@openagents/provider-account-schema": "workspace:*",
    "@openagents/sync-schema": "workspace:*",
    "@openagents/sync-worker": "workspace:*",
    "@openauthjs/openauth": "^0.4.3",
    "@orpc/client": "1.14.5",
    "arctic": "^2.2.2",
    "effect": "4.0.0-beta.70",
    "effect-cf": "0.13.1",
    "hono": "^4.12.23",
    "stripe": "^22.2.0"
  }
}
