{
  "name": "@openagentsinc/api-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/cloudrun/server.ts",
    "build": "pnpm --dir ../../apps/start run build && vp pack src/cloudrun/server.ts --out-dir dist-cloudrun --format esm --platform node --target node24",
    "deploy": "bash scripts/deploy-cloudrun.sh production",
    "deploy:staging": "bash scripts/deploy-cloudrun.sh staging",
    "smoke:cs336-a2:device-capability": "vitest run src/training-device-capability.test.ts src/training-device-admission-gates.test.ts src/training-run-window-routes.test.ts",
    "smoke:cs336-a3:isoflop": "vitest run src/training-scaling-sweep.test.ts src/training-run-window-routes.test.ts",
    "smoke:cs336-a4:data-refinery": "vitest run src/cs336-a4-data-refinery.test.ts src/cs336-a4-refinery-workload.test.ts src/training-data-refinery.test.ts src/training-run-window-routes.test.ts src/training-leaderboards.test.ts src/training-verification.test.ts",
    "smoke:cs336-a5:alignment": "vitest run src/cs336-a5-alignment-homework.test.ts src/cs336-a5-rollout-workload.test.ts src/training-alignment-evals.test.ts src/training-run-window-routes.test.ts src/training-leaderboards.test.ts",
    "smoke:tassadar:executor-trace": "vitest run src/tassadar-executor-trace-homework.test.ts src/training-verification.test.ts",
    "smoke:training-leaderboards": "vitest run src/training-leaderboards.test.ts src/training-run-window-routes.test.ts",
    "smoke:cs336-a1:no-spend": "vitest run src/cs336-a1-homework.test.ts src/cs336-a1-homework-workload.test.ts src/cs336-a1-real-gradient-workload.test.ts src/training-real-gradient-evidence.test.ts src/training-verification.test.ts",
    "smoke:training-runs:public": "vitest run src/training-run-window-routes.test.ts src/training-run-window-authority.test.ts src/training-run-public-copy-gate.test.ts",
    "smoke:training-validator:no-spend": "vitest run src/training-validator-assignments.test.ts src/training-verification.test.ts",
    "smoke:autopilot-coder:no-spend": "vitest run src/autopilot-work-routes.test.ts -t \"no-spend Autopilot Coder end-to-end smoke\"",
    "smoke:autopilot-coder:claude-agent-git-checkout": "vitest run src/autopilot-work-routes.test.ts -t \"claude_agent_task git_checkout\"",
    "marching-orders": "node --import tsx scripts/marching-orders-agent.ts",
    "agent-readiness:fleet-run": "node --import tsx scripts/agent-readiness-fleet-report-run.ts",
    "apollo-wave:dry-run": "node --experimental-strip-types scripts/apollo-wave-runner.ts dry-run",
    "apollo-wave:print-fixture": "node --experimental-strip-types scripts/apollo-wave-runner.ts print-fixture",
    "apollo-wave:live": "node --experimental-strip-types scripts/apollo-wave-runner.ts live",
    "glm-fleet:durability": "node --import tsx scripts/khala-glm-fleet-durability.ts",
    "pilot:glm-nvfp4": "node --import tsx scripts/khala-glm-nvfp4-pilot.ts",
    "smoke:autopilot-coder:paid": "vitest run src/autopilot-work-routes.test.ts -t \"paid Autopilot Coder end-to-end smoke\"",
    "smoke:autopilot-coder:rate-limit-rotation": "vitest run src/autopilot-rate-limit-rotation-smoke.test.ts src/provider-account-lease-policy.test.ts src/provider-account-failover-policy.test.ts",
    "smoke:probe-gepa-stage0": "node --import tsx scripts/probe-gepa-stage0-no-spend-campaign.ts",
    "smoke:qwen-remote-training": "node --import tsx scripts/qwen-remote-pylon-live-training.ts",
    "accept:managed-sandbox-box-live": "tsx scripts/managed-sandbox-box-live-acceptance.ts",
    "test": "vp test --root ../../../.. --run --project @openagentsinc/api-worker",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start:cloudrun": "node --import tsx ./src/cloudrun/server.ts",
    "typecheck:cloudrun": "tsc -p tsconfig.cloudrun.json --noEmit"
  },
  "dependencies": {
    "@liquid-js/qrcode-generator": "1.1.6",
    "@openagentsinc/agent-readiness": "workspace:*",
    "@openagentsinc/agent-runtime-schema": "workspace:*",
    "@openagentsinc/atif": "workspace:*",
    "@openagentsinc/authority": "workspace:*",
    "@openagentsinc/behavior-contracts": "workspace:*",
    "@openagentsinc/blueprint-contracts": "workspace:*",
    "@openagentsinc/durable-stream": "workspace:*",
    "@openagentsinc/effect-boundary": "workspace:*",
    "@openagentsinc/email-templates": "workspace:*",
    "@openagentsinc/forge-protocol": "workspace:*",
    "@openagentsinc/khala-sync": "workspace:*",
    "@openagentsinc/khala-sync-server": "workspace:*",
    "@openagentsinc/managed-sandbox-contract": "workspace:*",
    "@openagentsinc/mcp-contract": "workspace:*",
    "@openagentsinc/mullet-schema": "workspace:*",
    "@openagentsinc/mullet-sim": "workspace:*",
    "@openagentsinc/nip90": "workspace:*",
    "@openagentsinc/oa-infra": "workspace:*",
    "@openagentsinc/provider-account-schema": "workspace:*",
    "@openagentsinc/public-activity-timeline": "workspace:*",
    "@openagentsinc/qa-swarm-contract": "workspace:*",
    "@openagentsinc/reactor-contracts": "workspace:*",
    "@openagentsinc/runtime-platform": "workspace:*",
    "@openagentsinc/sarah": "workspace:*",
    "@openagentsinc/sync-schema": "workspace:*",
    "@openagentsinc/sync-worker": "workspace:*",
    "@openagentsinc/tassadar-executor": "workspace:*",
    "@openauthjs/openauth": "^0.4.3",
    "@orpc/client": "1.14.5",
    "arctic": "^2.2.2",
    "effect": "4.0.0-beta.94",
    "hono": "^4.12.23",
    "nostr-effect": "https://github.com/OpenAgentsInc/nostr-effect/archive/2bb57870eeeb214ed80ca8a275292f5e4dd89863.tar.gz",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@asciidev/box-sdk": "0.0.24",
    "@openagentsinc/khala-sync-client": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "playwright": "^1.61.0",
    "vitest": "^4.1.8"
  }
}
