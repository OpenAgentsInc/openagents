{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "openagents-autopilot",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-02",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
  "routes": [
    {
      "pattern": "openagents.com",
      "custom_domain": true,
    },
    {
      "pattern": "auth.openagents.com",
      "custom_domain": true,
    },
    {
      "pattern": "sites.openagents.com",
      "custom_domain": true,
    },
  ],
  "send_email": [
    {
      "name": "EMAIL",
    },
  ],
  "vars": {
    "GITHUB_CLIENT_ID": "Ov23lirHI1DWTzZ1zT1u",
    "INFERENCE_GATEWAY_ENABLED": "true",
    "INFERENCE_FREE_TIER_ENABLED": "true",
    // KS-8 Pylon read cutover (#8315): Pylon dispatch, runner-status, and raw
    // Codex proof metadata reads serve from Cloud SQL with bounded retry and D1
    // fallback. Roll back by setting this to `d1`.
    "KHALA_SYNC_PYLON_READS": "postgres",
    // KS-8.6 Artanis read cutover (#8335, TEMPORARY compare soak): dual-write
    // has been live since 357562dcfc; this reads BOTH stores, serves D1, and
    // logs `khala_sync_artanis_read_compare_mismatch` on any drift. Covers the
    // idempotency read in ArtanisScheduledRunner.runTick plus operator-console
    // and public-report latest-row reads. Roll back to `d1` at any time; the
    // remaining five cron ticks' own decision-making reads stay D1-direct
    // regardless of this flag (no Postgres reader wired for them yet).
    "KHALA_SYNC_ARTANIS_READS": "compare",
    // KS-8.16 follow-up Forge READ cutover (#8358): `postgres` SERVES the
    // canonical `listRefs` ref advertisement (the §3.13 git-ls-remote-twin
    // surface) from the Postgres twin, and is FAIL-SOFT — any Postgres
    // error falls back to the D1 authority for that one call and logs
    // `khala_sync_forge_postgres_read_serve_failed`, so the advertisement
    // can never break. Gated on a fresh full backfill --verify (exact
    // ref-set digest match) + a live ground-truth `git`-advertisement
    // cross-check + zero compare-mode drift. Roll back to `d1` at any time.
    // WRITE authority stays on D1 (the `makePostgresForgeGitCanonicalStore`
    // FOR-UPDATE ref-lock port is built + tested but NOT wired as write
    // authority — that domain-wide write cutover is separate follow-up).
    "KHALA_SYNC_FORGE_READS": "postgres",
    // KS-8.14 business funnel read cutover (#8360): production
    // backfill/--restart/--verify are green across all 32 tables; the
    // compare-mode soak (2026-07-05) showed zero
    // khala_sync_business_read_compare_mismatch events. `postgres` serves
    // REAL Postgres reads ONLY for the bounded allowlist
    // BUSINESS_DOMAIN_POSTGRES_SERVED_READ_TABLES in business-domain-store.ts
    // (today: business_funnel_events alone — the public funnel dashboard's
    // two full-table aggregate reads, an append-only firehose table with no
    // write-path decision coupling). Every other comparable-select in this
    // domain (the escalation pager, referral-attribution existence-checks,
    // pipeline/order/referral list reads) stays D1-served under `postgres`
    // PERMANENTLY, logging khala_sync_business_postgres_reads_deferred —
    // never a blanket flip. Fail-soft: a Postgres read error on the
    // allowlisted surface falls back to D1
    // (khala_sync_business_postgres_read_serve_failed). Epic-gated ops
    // decision recorded on #8282. Roll back to `d1` at any time.
    "KHALA_SYNC_BUSINESS_READS": "postgres",
    // KS-8.9 decommission follow-up (#8336): bounded non-gate read
    // allowlist, FULLY INDEPENDENT of KHALA_SYNC_ENTITLEMENTS_READS (the six
    // enforcement gate reads, which stay untouched at their default `d1`).
    // The compare-mode soak (2026-07-05, live wrangler tail across the
    // launch-status and agent-profile routes) showed zero
    // khala_sync_entitlements_non_gate_read_compare_mismatch events.
    // `postgres` serves ONLY countActiveOrangeChecks,
    // readActiveOrangeCheckByActorRef (orange-check-entitlements.ts), and
    // readPublicPrivacyReceipt (inference-privacy-receipt-routes.ts) for
    // real, fail-soft to D1 on any error
    // (khala_sync_entitlements_non_gate_postgres_read_fallback). Every
    // enforcement/idempotency-decision read in this domain stays D1-only
    // permanently regardless of this flag. Production
    // backfill/--restart/--verify are green across all 28 tables. Epic-gated
    // ops decision recorded on #8282. Roll back to `d1` at any time.
    "KHALA_SYNC_ENTITLEMENTS_NON_GATE_READS": "postgres",
    // #8362 follow-up: bounded identity/auth non-gate read allowlist,
    // FULLY INDEPENDENT of KHALA_SYNC_IDENTITY_READS (the auth-decision gate
    // reads, which stay untouched at their default `d1` — there is no routed
    // auth read in this domain, and this flag can never change that). Governs
    // ONLY `IdentityAuthNonGateReads.providerAccountPoolStateByUserId`
    // (provider-account-usage-routes.ts's `listPoolState`, an admin-only,
    // single-table `provider_accounts` pool-state projection with no
    // cross-domain JOIN and no read-your-own-write consumer). Compare-mode
    // soak (2026-07-05, ~5 min live `wrangler tail`, ~44k lines of real
    // production traffic observed) showed zero
    // khala_sync_identity_non_gate_read_compare_mismatch events (the admin
    // route itself saw no organic hits in that window — thin-by-vacuity for
    // this specific route, same honest caveat as the KS-8.17 near-zero-
    // traffic precedent, but the fail-soft routing itself ran live against
    // real traffic with zero errors). `postgres` now serves this ONE read
    // from Postgres for real, fail-soft to D1 on any error
    // (khala_sync_identity_non_gate_postgres_read_fallback) — safe because
    // this read never decides an allow/deny/lease/dedupe outcome. Roll back
    // to `d1` at any time; this can never affect an auth decision.
    "KHALA_SYNC_IDENTITY_NON_GATE_READS": "postgres",
    // KS-8.17 follow-up supervision long-tail read cutover (#8361): dual-write
    // has been live since 4acd3704c2; production backfill/second-sweep/
    // --verify are green across all 29 tables, re-confirmed fresh after real
    // organic writes landed in a sibling table since the first pass. `postgres`
    // now REALLY serves the one bounded public projection surface in this
    // domain — `omni_public_proof_bundles` (read by both the redacted public
    // handoff page and the operator JSON view) — through
    // `makeOmniPublicProofBundlePostgresServerForEnv`, fail-soft to D1 on any
    // Postgres error. This table is genuinely zero-traffic (0 rows in D1 AND
    // Postgres, both environments) so a live soak is structurally
    // unavailable; the accepted evidence instead is the contract suite +
    // repeated clean `--verify`, matching the KS-8.14 business-domain
    // allowlist precedent (#8360). Every other read in this domain stays
    // D1-only. Roll back to `d1` or `compare` at any time.
    "KHALA_SYNC_SUPERVISION_READS": "postgres",
    // #6408 "fleet never silently stalls" watchdog (1-min cron). Detection is
    // default-ON so a live stall is flagged immediately. Recovery is also ON but
    // is a no-op unless FLEET_WATCHDOG_OWNER_PYLON_REFS lists the owner pylon(s)
    // whose abandoned leases may be auto-flushed (a safety scoping). Window /
    // threshold default to a rolling 5-min window and ~1M own-capacity tokens.
    "FLEET_WATCHDOG_ENABLED": "true",
    "FLEET_WATCHDOG_RECOVERY_ENABLED": "true",
    "FLEET_WATCHDOG_WINDOW_MINUTES": "5",
    "FLEET_WATCHDOG_STALL_THRESHOLD_TOKENS": "1000000",
    "FLEET_WATCHDOG_STALE_LEASE_MIN_AGE_MINUTES": "10",
    "FLEET_WATCHDOG_OWNER_PYLON_REFS": "",
    // Default-ON redacted, private-by-default trace capture for free-tier traffic
    // (#6293, EPIC redaction #6219). The master switch arms the Khala chat->ATIF
    // trace emitter; the free-tier flag makes capture default-on for free traffic
    // without a per-request opt-in. Captured traces are REDACTED (trace-redaction.ts,
    // scrub-then-tripwire-backstop), stored owner_only/private by default
    // (KHALA_AUTO_CAPTURE_VISIBILITY), and EXCLUDE paid-privacy callers fail-closed
    // (#6295, INFERENCE_CONFIDENTIAL_COMPUTE_ENABLED). Public sharing is opt-in only.
    "KHALA_CHAT_TRACE_EMIT_ENABLED": "true",
    "KHALA_FREE_TIER_TRACE_CAPTURE_DEFAULT": "true",
    // Internal/ops account allowlist (#6298 demand-attribution + #6232 free-tier
    // quota exemption). Comma-separated account refs. Two effects, both scoped to
    // exactly these refs:
    //   1. DEMAND ATTRIBUTION: traffic is auto-classified `demand_kind=internal`
    //      REGARDLESS of request headers, so our own dogfood (heartbeat / canary /
    //      Terminal-Bench on the ops key; Artanis/Raynor agent testing) never
    //      pollutes the external trace corpus (`agent_traces`) or the demand
    //      ledger (`token_usage_events`). A header-less listed account defaults
    //      `demand_source` to `internal_account`; a specific internal-source
    //      header (e.g. `harbor_terminal_bench`) is preserved.
    //   2. FREE-TIER QUOTA EXEMPTION: a free-tier key on a listed account is
    //      quota-EXEMPT on the free Khala lane — it never hits the per-key daily
    //      quota (2,000 req / 2.5M tok) and never falls through to the 402 on
    //      quota grounds, so sustained internal testing is never blocked.
    //      EXTERNAL (non-allowlist) free keys keep the unchanged daily limit; the
    //      premium/no-resale/metering invariants are unchanged for everyone.
    // Refs: ops/heartbeat/canary/Terminal-Bench key (7a6d6dab), the Artanis
    // registered agent (ed6d486e), and the Raynor agent (cae3afe7). Empty/unset
    // => no-op.
    "INFERENCE_INTERNAL_ACCOUNT_REFS": "agent:user_7a6d6dab-b198-4ee8-b7bf-2e00385f9139,agent:user_ed6d486e-612a-4fac-a9a9-44f7e5709505,agent:user_cae3afe7-0e45-4a07-8bc9-eb80a27bb283",
    // Owner-controlled inference balance-gate exemption (#6180). Arms the gate
    // ONLY; it is a no-op until a verified owner key is granted into
    // `inference_operator_exemption`. Own-infra/non-premium lanes only; exempt
    // usage bills `operator_credit` (zero debit). Lets approved owner/internal
    // keys test our own hourly lanes (e.g. Khala/GPT-OSS) without funding.
    "INFERENCE_OPERATOR_EXEMPTION_ENABLED": "on",
    // Durable-stream Rank-1 resumable inference (#6058, EPIC #6056). LIVE: every
    // streamed `/api/v1/chat/completions` completion is teed into the per-request
    // `INFERENCE_DURABLE_STREAM` Durable Object so a client disconnect can resume
    // by offset via `/v1/chat/completions/durable/{requestId}`. Metering still
    // settles EXACTLY ONCE on the real upstream EOF and NEVER on a replay.
    "INFERENCE_DURABLE_STREAM_ENABLED": "true",
    // Hydralisk GPT-OSS 20B Khala lane (#6155, hydralisk#1). The transport URL
    // and bearer are Worker secrets; these committed vars only arm the bounded
    // model-id route after the 2026-06-24 public-origin L4/vLLM smoke produced
    // public-safe capability + receipt evidence.
    "HYDRALISK_GPT_OSS_20B_ENABLED": "ready",
    "HYDRALISK_GPT_OSS_20B_PREFLIGHT_REF": "preflight.hydralisk.gpt_oss_20b.l4.20260624T002313Z",
    "HYDRALISK_GPT_OSS_20B_RECEIPT_REF": "receipt.hydralisk.gpt_oss_20b.l4.hydralisk-run-48adcddbb0ff47e097685da23f17cea6",
    // Hydralisk GPT-OSS 120B high-memory lane. The transport URL and bearer are
    // Worker secrets; these committed vars only arm the model-id route after the
    // 2026-06-24 H100/vLLM smoke produced public-safe capability + receipt
    // evidence.
    "HYDRALISK_GPT_OSS_120B_ENABLED": "ready",
    "HYDRALISK_GPT_OSS_120B_PREFLIGHT_REF": "preflight.hydralisk.gpt_oss_120b.h100.20260624T022946Z",
    "HYDRALISK_GPT_OSS_120B_RECEIPT_REF": "receipt.hydralisk.gpt_oss_120b.h100.hydralisk-run-2969ab61fcf44c3085c5e9f2bc513f11",
    // Hydralisk GLM-5.2-REAP-504B private G4 fleet — the PRIMARY Khala backing
    // (#6262 #6253). The 10 replica origin URLs and bearer tokens are Worker
    // secrets (HYDRALISK_GLM_52_REAP_504B_<REPLICA_ID>_BASE_URL/_BEARER_TOKEN,
    // uploaded via `wrangler secret put` — never committed). These committed vars
    // keep the route armed only for completion-capable replicas. A 2026-06-27
    // live completion probes recovered the newer Spot origins; the terminated
    // `g4-4g-b-20260625154532` host remains listed for readiness/accounting but
    // is marked draining until capacity returns and host-level repair re-proves
    // `/health`, `/v1/models`, and `/v1/chat/completions`.
    // A GLM replica failure is retryable inside the pool first, then the lane can
    // still overflow to Khala fallbacks. GPT-OSS is not in the main Khala fallback
    // thread.
    "HYDRALISK_GLM_52_REAP_504B_ENABLED": "ready",
    "HYDRALISK_GLM_52_REAP_504B_MODEL_ID": "openagents/glm-5.2-reap-504b",
    "HYDRALISK_GLM_52_REAP_504B_REPLICA_IDS": "g4-4g-b-20260625154532,g4-4g-central1f-spot-20260625203000,g4-4g-east1b-spot-20260625203000,g4-4g-east1d-spot-20260625203000,g4-4g-east5a-spot-20260625203000,g4-4g-east5b-spot-20260625203000,g4-4g-east5c-spot-20260625211500,g4-4g-south1b-spot-20260625211500,g4-4g-west1a-spot-20260625203000,g4-8g-b-20260624214500",
    "HYDRALISK_GLM_52_REAP_504B_MAX_INFLIGHT": "1",
    "HYDRALISK_GLM_52_REAP_504B_PROFILE_REF": "profile.hydralisk.glm_52_reap_504b.g4_tp4_minp.v1",
    "HYDRALISK_GLM_52_REAP_504B_COST_PROFILE_REF": "cost_profile.hydralisk.glm_52_reap_504b.g4_4g.spot.2026_06_25",
    "HYDRALISK_GLM_52_REAP_504B_PREFLIGHT_REF": "preflight.hydralisk.glm_52_reap_504b.g4.20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_RECEIPT_REF": "receipt.hydralisk.glm_52_reap_504b.g4.roster-10replica-20260626T033107Z",
    // Public-safe scheduled fleet watchdog for #6311. Every minute the Worker
    // cron probes each configured GLM replica's /health and /v1/models routes,
    // records exact zero-token heartbeat rows, and projects the latest typed
    // status through /v1/gateway/glm-fleet/readiness. Warm completions stay off
    // by default here; serving traffic and explicit smokes are what spend tokens.
    "HYDRALISK_GLM_52_REAP_504B_HEARTBEAT_ENABLED": "true",
    "HYDRALISK_GLM_52_REAP_504B_HEARTBEAT_CADENCE_MINUTES": "1",
    // Per-replica arming for the 10-host fleet. With REPLICA_IDS set, the pool
    // resolver does NOT fall back to legacy unsuffixed keys, so each replica must
    // carry its own _ENABLED + evidence refs (URL/bearer live in Worker secrets).
    // Draining means "do not route" while keeping the replica visible to the
    // readiness surface until it is host-repaired and re-smoked.
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_B_20260625154532_ENABLED": "ready",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_B_20260625154532_DRAINING": "true",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_B_20260625154532_PROFILE_REF": "profile.hydralisk.glm_52_reap_504b.g4_tp4_minp.v1",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_B_20260625154532_COST_PROFILE_REF": "cost_profile.hydralisk.glm_52_reap_504b.g4_4g.spot.2026_06_25",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_B_20260625154532_PREFLIGHT_REF": "preflight.hydralisk.glm_52_reap_504b.g4.20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_B_20260625154532_RECEIPT_REF": "receipt.hydralisk.glm_52_reap_504b.g4.roster-10replica-20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_CENTRAL1F_SPOT_20260625203000_ENABLED": "ready",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_CENTRAL1F_SPOT_20260625203000_DRAINING": "true",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_CENTRAL1F_SPOT_20260625203000_PROFILE_REF": "profile.hydralisk.glm_52_reap_504b.g4_tp4_minp.v1",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_CENTRAL1F_SPOT_20260625203000_COST_PROFILE_REF": "cost_profile.hydralisk.glm_52_reap_504b.g4_4g.spot.2026_06_25",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_CENTRAL1F_SPOT_20260625203000_PREFLIGHT_REF": "preflight.hydralisk.glm_52_reap_504b.g4.20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_CENTRAL1F_SPOT_20260625203000_RECEIPT_REF": "receipt.hydralisk.glm_52_reap_504b.g4.roster-10replica-20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST1B_SPOT_20260625203000_ENABLED": "ready",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST1B_SPOT_20260625203000_PROFILE_REF": "profile.hydralisk.glm_52_reap_504b.g4_tp4_minp.v1",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST1B_SPOT_20260625203000_COST_PROFILE_REF": "cost_profile.hydralisk.glm_52_reap_504b.g4_4g.spot.2026_06_25",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST1B_SPOT_20260625203000_PREFLIGHT_REF": "preflight.hydralisk.glm_52_reap_504b.g4.20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST1B_SPOT_20260625203000_RECEIPT_REF": "receipt.hydralisk.glm_52_reap_504b.g4.roster-10replica-20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST1D_SPOT_20260625203000_ENABLED": "ready",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST1D_SPOT_20260625203000_PROFILE_REF": "profile.hydralisk.glm_52_reap_504b.g4_tp4_minp.v1",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST1D_SPOT_20260625203000_COST_PROFILE_REF": "cost_profile.hydralisk.glm_52_reap_504b.g4_4g.spot.2026_06_25",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST1D_SPOT_20260625203000_PREFLIGHT_REF": "preflight.hydralisk.glm_52_reap_504b.g4.20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST1D_SPOT_20260625203000_RECEIPT_REF": "receipt.hydralisk.glm_52_reap_504b.g4.roster-10replica-20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5A_SPOT_20260625203000_ENABLED": "ready",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5A_SPOT_20260625203000_PROFILE_REF": "profile.hydralisk.glm_52_reap_504b.g4_tp4_minp.v1",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5A_SPOT_20260625203000_COST_PROFILE_REF": "cost_profile.hydralisk.glm_52_reap_504b.g4_4g.spot.2026_06_25",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5A_SPOT_20260625203000_PREFLIGHT_REF": "preflight.hydralisk.glm_52_reap_504b.g4.20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5A_SPOT_20260625203000_RECEIPT_REF": "receipt.hydralisk.glm_52_reap_504b.g4.roster-10replica-20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5B_SPOT_20260625203000_ENABLED": "ready",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5B_SPOT_20260625203000_PROFILE_REF": "profile.hydralisk.glm_52_reap_504b.g4_tp4_minp.v1",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5B_SPOT_20260625203000_COST_PROFILE_REF": "cost_profile.hydralisk.glm_52_reap_504b.g4_4g.spot.2026_06_25",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5B_SPOT_20260625203000_PREFLIGHT_REF": "preflight.hydralisk.glm_52_reap_504b.g4.20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5B_SPOT_20260625203000_RECEIPT_REF": "receipt.hydralisk.glm_52_reap_504b.g4.roster-10replica-20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5C_SPOT_20260625211500_ENABLED": "ready",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5C_SPOT_20260625211500_PROFILE_REF": "profile.hydralisk.glm_52_reap_504b.g4_tp4_minp.v1",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5C_SPOT_20260625211500_COST_PROFILE_REF": "cost_profile.hydralisk.glm_52_reap_504b.g4_4g.spot.2026_06_25",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5C_SPOT_20260625211500_PREFLIGHT_REF": "preflight.hydralisk.glm_52_reap_504b.g4.20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_EAST5C_SPOT_20260625211500_RECEIPT_REF": "receipt.hydralisk.glm_52_reap_504b.g4.roster-10replica-20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_SOUTH1B_SPOT_20260625211500_ENABLED": "ready",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_SOUTH1B_SPOT_20260625211500_PROFILE_REF": "profile.hydralisk.glm_52_reap_504b.g4_tp4_minp.v1",
