    "HYDRALISK_GLM_52_REAP_504B_G4_4G_WEST1A_SPOT_20260625203000_PROFILE_REF": "profile.hydralisk.glm_52_reap_504b.g4_tp4_minp.v1",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_WEST1A_SPOT_20260625203000_COST_PROFILE_REF": "cost_profile.hydralisk.glm_52_reap_504b.g4_4g.spot.2026_06_25",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_WEST1A_SPOT_20260625203000_PREFLIGHT_REF": "preflight.hydralisk.glm_52_reap_504b.g4.20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_4G_WEST1A_SPOT_20260625203000_RECEIPT_REF": "receipt.hydralisk.glm_52_reap_504b.g4.roster-10replica-20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_8G_B_20260624214500_ENABLED": "ready",
    "HYDRALISK_GLM_52_REAP_504B_G4_8G_B_20260624214500_MAX_INFLIGHT": "2",
    "HYDRALISK_GLM_52_REAP_504B_G4_8G_B_20260624214500_PROFILE_REF": "profile.hydralisk.glm_52_reap_504b.g4_tp4_minp.v1",
    "HYDRALISK_GLM_52_REAP_504B_G4_8G_B_20260624214500_COST_PROFILE_REF": "cost_profile.hydralisk.glm_52_reap_504b.g4_4g.spot.2026_06_25",
    "HYDRALISK_GLM_52_REAP_504B_G4_8G_B_20260624214500_PREFLIGHT_REF": "preflight.hydralisk.glm_52_reap_504b.g4.20260626T033107Z",
    "HYDRALISK_GLM_52_REAP_504B_G4_8G_B_20260624214500_RECEIPT_REF": "receipt.hydralisk.glm_52_reap_504b.g4.roster-10replica-20260626T033107Z",
    // Khala provider backing (#6198, #6259). Operator-only, non-secret routing
    // knob: customers still see/request ONLY `openagents/khala`. Set to the
    // Hydralisk-backed policy value while the router currently starts the
    // public Khala chain on the pinned OpenRouter Granite lane before Vertex
    // Gemini/Fireworks/Hydralisk, instead of Fireworks DeepSeek.
    // GPT-OSS is not in the main Khala fallback thread. Any value
    // other than the deepseek-v4-flash aliases resolves to the Hydralisk backing
    // (model-serving-policy.ts:resolveKhalaBackingModel); Fireworks remains armed
    // for the OPEN class and as named-model routing, just not as the Khala primary.
    "KHALA_BACKING_MODEL": "hydralisk-glm-5.2-reap-504b",
    // OpenAgents/Pylon serving-fabric lane (#6089). The proxy route URL and
    // bearer are Worker secrets; these committed vars only arm the route after
    // the admitted GCloud L4 Pylon's durable HTTPS canary returned public-safe
    // parity/canary/replay evidence.
    "OPENAGENTS_NETWORK_GATEWAY_ROUTE_READY": "ready",
    "OPENAGENTS_NETWORK_GATEWAY_APPROVAL_REF": "approval.owner.khala.6089.gateway_route.2026_06_24",
    "OPENAGENTS_NETWORK_SERVING_PREFLIGHT_REF": "preflight.pylon.real_serving.ready.v0_1",
    "OPENAGENTS_NETWORK_SERVING_RECEIPT_REF": "serve.pylon.gateway_proxy.cAR4xZXQagyw7yBsjeO6IG",
    "OPENAGENTS_NETWORK_REPLAY_CHALLENGE_REF": "challenge.pylon.serving.GuUBPkgNgLRtTCgkkO-s",
    "OPENAGENTS_NETWORK_ADMITTED_PYLON_REF": "gcloud.gswarm508-clean2-20260325044551-contrib",
    "OPENAGENTS_NETWORK_PYLON_SERVING_CAPABILITY_REF": "pylon.capability.serving.whole_small_model.v0.6",
    "OPENAGENTS_NETWORK_PYLON_SERVING_LANE_REF": "lane.openagents.pylon.vllm.whole_small_model.v1",
    "OPENAGENTS_NETWORK_SPARK_PAYOUT_TARGET_REF": "payout.spark.aab6617b16f096dfe02fc6b4",
    "OPENAUTH_CLIENT_ID": "openagents-web",
    "OPENAUTH_ISSUER_URL": "https://auth.openagents.com",
    "OPENAGENTS_APP_URL": "https://openagents.com",
    "RESEND_FROM_EMAIL": "OpenAgents <chris+sites@openagents.com>",
    "RESEND_REPLY_TO_EMAIL": "chris+sites@openagents.com",
    "MDK_CHECKOUT_CONFIG_REF": "config.openagents.mdk.cloudflare_container",
    "MDK_CHECKOUT_CREDENTIAL_BINDING_REF": "credential_binding.openagents.mdk.cloudflare_worker_binding",
    "MDK_CHECKOUT_ENVIRONMENT": "production",
    "MDK_CHECKOUT_PATH_BASE": "/checkout",
    "MDK_CHECKOUT_PROVIDER_REF": "provider.openagents.mdk.cloudflare_container",
    "MDK_CHECKOUT_ROUTE_KIND": "self_hosted_mdkd_sidecar",
    "MDK_CHECKOUT_ROUTE_URL": "https://openagents.com/api/mdk",
    "MDK_CHECKOUT_WEBHOOK_SOURCE": "sdk_node_control",
    "SHC_CONTROL_API_URL": "http://23.182.128.195.sslip.io/v1/codex-runs",
    "SHC_DISPATCH_MODE": "live",
  },
  // Cloudflare Browser Rendering binding (#6205). Managed headless Chrome,
  // driven from the Worker via `@cloudflare/playwright`'s `launch(env.BROWSER)`.
  // The admin-gated `/api/admin/cf-browser-smoke` route proves it on prod; the
  // qa-runner `cfBrowserBackend` drives real QA runs through the same binding.
  "browser": {
    "binding": "BROWSER",
  },
  "containers": [
    {
      "class_name": "MdkSidecarContainer",
      "image": "../../services/mdk-sidecar/Dockerfile",
      "image_build_context": "../../services/mdk-sidecar",
      "instance_type": "basic",
      "max_instances": 2,
    },
    {
      "class_name": "MdkTreasuryContainer",
      "image": "../../services/mdk-treasury/Dockerfile",
      "image_build_context": "../../services/mdk-treasury",
      "instance_type": "basic",
      "max_instances": 1,
    },
    {
      "class_name": "MdkTipsBufferContainer",
      "image": "../../services/mdk-tips-buffer/Dockerfile",
      "image_build_context": "../../services/mdk-tips-buffer",
      "instance_type": "basic",
      "max_instances": 1,
    },
  ],
  "kv_namespaces": [
    {
      "binding": "AUTH_STORAGE",
      "id": "d6b40d28e0a640bfb29d50c7afe458b1",
      "preview_id": "02566e7567b6479ebdada57c93991383",
    },
  ],
  "assets": {
    "directory": "../../apps/web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true,
  },
  "dispatch_namespaces": [
    {
      "binding": "SITES_DISPATCH",
      "namespace": "openagents-sites-production",
    },
  ],
  // Direct worker-to-worker binding for the relay-health NIP-11 probe leg
  // (#4865): same-zone plain-GET subrequests to the relay's custom domain
  // fail from inside this worker, while service bindings always invoke
  // the target worker directly.
  "services": [
    {
      "binding": "MARKET_RELAY_SERVICE",
      "service": "openagents-market-relay",
    },
  ],
  "d1_databases": [
    {
      "binding": "OPENAGENTS_DB",
      "database_name": "openagents-autopilot",
      "database_id": "9644ea09-f682-4971-98de-e0c791cb67fb",
      "migrations_dir": "migrations",
    },
  ],
  // Khala Sync Cloud SQL Postgres via Hyperdrive (KS-0.2, #8284; SPEC §4 in
  // docs/khala-sync/SPEC.md). TRANSACTION-MODE pooling: Worker request paths
  // must use single-transaction statements only — no LISTEN/NOTIFY, no session
  // PREPARE, no advisory locks. Config ids are public references, not secrets;
  // origin credentials live only inside the Hyperdrive config (redacted
  // connection docs: packages/khala-sync-server/README.md).
  "hyperdrive": [
    {
      "binding": "KHALA_SYNC_DB",
      "id": "6cd885288e5b4b2f8fd2d76200c980bf",
    },
  ],
  // Khala Sync compare-mode soak observability (#8282 shared follow-up):
  // one durable Analytics Engine data point per compare-mode read across
  // the KS-8 domains, additive to the existing per-call
  // `khala_sync_*_compare_mismatch` diagnostics. Query via
  // `packages/khala-sync-server/scripts/query-compare-soak.ts` (Analytics
  // Engine SQL API). Writes are fail-soft (see
  // `@openagentsinc/khala-sync-server`'s `compare-soak-metrics.ts`) — a
  // missing binding or a write fault never affects the compare-mode read
  // path it instruments.
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "khala_sync_compare_soak",
    },
  ],
  // Smart Placement (#8284 acceptance) is deliberately NOT enabled: this
  // Worker serves the whole site's static assets with `run_worker_first:
  // true`, and Wrangler warns that Smart Placement would move ALL requests
  // (including asset serving) with the Worker — a site-wide latency risk.
  // Revisit when the Khala Sync request paths justify a placement decision
  // scoped to a dedicated Worker.
  "r2_buckets": [
    {
      "binding": "ARTIFACTS",
      "bucket_name": "openagents-autopilot-artifacts",
    },
  ],
  "queues": {
    "producers": [
      {
        "binding": "RUNNER_EVENTS",
        "queue": "openagents-autopilot-runner-events",
      },
      {
        "binding": "ADJUTANT_ENRICHMENT_QUEUE",
        "queue": "openagents-adjutant-enrichment-jobs",
      },
      {
        "binding": "EVENT_LEDGER_INGEST_QUEUE",
        "queue": "openagents-event-ledger-ingest",
      },
      // KS-8.4 (#8315): raw Codex payloads stay in R2; metadata row writes move
      // off the request path and through this queue before D1/Postgres indexing.
      {
        "binding": "PYLON_CODEX_RAW_EVENT_METADATA_QUEUE",
        "queue": "openagents-pylon-codex-raw-event-metadata",
      },
    ],
    "consumers": [
      {
        "queue": "openagents-adjutant-enrichment-jobs",
        "max_batch_size": 1,
        "max_retries": 3,
      },
      {
        "queue": "openagents-event-ledger-ingest",
        "max_batch_size": 1,
        "max_retries": 3,
      },
      {
        "queue": "openagents-pylon-codex-raw-event-metadata",
        "max_batch_size": 25,
        "max_retries": 3,
      },
    ],
  },
  "triggers": {
    "crons": ["* * * * *"],
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SYNC_ROOM",
        "class_name": "SyncRoomDurableObject",
      },
      {
        "name": "MDK_SIDECAR",
        "class_name": "MdkSidecarContainer",
      },
      {
        "name": "MDK_TREASURY",
        "class_name": "MdkTreasuryContainer",
      },
      {
        "name": "MDK_TIPS_BUFFER",
        "class_name": "MdkTipsBufferContainer",
      },
      // Durable-stream Rank-1 resumable inference (#6058). One SQLite-class DO
      // per request id holds that completion's durable offset log. INERT unless
      // INFERENCE_DURABLE_STREAM_ENABLED is on AND the producer is wired.
      {
        "name": "INFERENCE_DURABLE_STREAM",
        "class_name": "DurableInferenceStreamObject",
      },
      // Background-agent cron scheduler (BA-B2). The Worker scheduled() hook wakes
      // exactly this named DO, which serializes due-trigger ticks across isolates.
      {
        "name": "AGENT_DEFINITION_SCHEDULER",
        "class_name": "AgentDefinitionSchedulerDurableObject",
      },
      {
        "name": "EVENT_LEDGER_OWNER",
        "class_name": "EventLedgerOwnerDurableObject",
      },
      // Khala Sync hub (KS-4.2, #8295). One SQLite-class DO per scope
      // (`idFromName(scope)`) holds the recent changelog window + hibernating
      // WebSockets; cache/fan-out only, Postgres stays authoritative
      // (docs/khala-sync/SPEC.md §5).
      {
        "name": "KHALA_SYNC_HUB",
        "class_name": "KhalaSyncHubDO",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SyncRoomDurableObject"],
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["MdkSidecarContainer"],
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["MdkTreasuryContainer"],
    },
    {
      "tag": "v4",
      "new_sqlite_classes": ["MdkTipsBufferContainer"],
    },
    {
      "tag": "v5",
      "new_sqlite_classes": ["DurableInferenceStreamObject"],
    },
    {
      "tag": "v6",
      "new_sqlite_classes": ["GlmStressSchedulerDurableObject"],
    },
    {
      "tag": "v7",
      "new_sqlite_classes": ["AgentDefinitionSchedulerDurableObject"],
    },
    {
      "tag": "v8",
      "new_sqlite_classes": ["EventLedgerOwnerDurableObject"],
    },
    {
      "tag": "v9",
      "new_sqlite_classes": ["KhalaSyncHubDO"],
    },
    {
      "tag": "v10",
      "deleted_classes": ["GlmStressSchedulerDurableObject"],
    },
  ],
  "env": {
    "staging": {
      "name": "openagents-staging",
      "workers_dev": true,
      "preview_urls": true,
      "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
        "logs": {
          "enabled": true,
          "head_sampling_rate": 1,
          "persist": true,
          "invocation_logs": true,
        },
        "traces": {
          "enabled": true,
          "persist": true,
          "head_sampling_rate": 1,
