      },
      "routes": [],
      "vars": {
        "ARTANIS_SCHEDULED_RUNNER_ENABLED": "false",
        "INFERENCE_GATEWAY_ENABLED": "true",
        "INFERENCE_FREE_TIER_ENABLED": "true",
        // KS-8 Pylon read cutover (#8315), staging parity for the production
        // Cloud SQL read path. Roll back by setting this to `d1`.
        "KHALA_SYNC_PYLON_READS": "postgres",
        // KS-8.6 Artanis read cutover (#8335, TEMPORARY compare soak), staging
        // parity. ARTANIS_SCHEDULED_RUNNER_ENABLED is false on staging so this
        // mainly exercises operator-console/public-report reads here; the
        // production var is the one under live soak observation.
        "KHALA_SYNC_ARTANIS_READS": "compare",
        // KS-8.16 follow-up Forge READ cutover (#8358), staging parity for
        // the production Postgres-served, fail-soft ref advertisement.
        "KHALA_SYNC_FORGE_READS": "postgres",
        // KS-8.14 business funnel read cutover (#8360), staging parity for
        // the production bounded postgres read serving.
        "KHALA_SYNC_BUSINESS_READS": "postgres",
        // KS-8.9 decommission follow-up (#8336), staging parity for the
        // production bounded non-gate read allowlist soak.
        "KHALA_SYNC_ENTITLEMENTS_NON_GATE_READS": "postgres",
        // #8362 follow-up, staging parity for the production bounded
        // identity/auth non-gate read allowlist Postgres-serving soak.
        "KHALA_SYNC_IDENTITY_NON_GATE_READS": "postgres",
        // KS-8.17 follow-up supervision long-tail read cutover (#8361),
        // staging parity for the production bounded proof-bundle Postgres
        // read serving.
        "KHALA_SYNC_SUPERVISION_READS": "postgres",
        // Internal/ops account allowlist (#6298 demand + #6232 quota exemption) —
        // staging too, so dogfood classifies `demand_kind=internal` consistently
        // and internal testing accounts (ops/heartbeat/canary, Artanis, Raynor)
        // are free-tier quota-EXEMPT on the free Khala lane. External free keys
        // keep the unchanged daily limit.
        "INFERENCE_INTERNAL_ACCOUNT_REFS": "agent:user_7a6d6dab-b198-4ee8-b7bf-2e00385f9139,agent:user_ed6d486e-612a-4fac-a9a9-44f7e5709505,agent:user_cae3afe7-0e45-4a07-8bc9-eb80a27bb283",
        // Durable-stream Rank-1 resumable inference (#6058) — LIVE on staging too
        // (the DO binding + migration are added to this env below).
        "INFERENCE_DURABLE_STREAM_ENABLED": "true",
        // Ep239 "Let's Make Money" loop surfaces — armed on STAGING ONLY so
        // external agent-testers can exercise the inert/scaffold endpoints.
        // Production (the top-level config above) leaves these unset, so the
        // markets/marketplace/cloud surfaces stay default-OFF (404) on prod.
        "CLOUD_FINE_TUNING_ENABLED": "true",
        "CLOUD_SANDBOX_COMPUTE_ENABLED": "true",
        "MARKETPLACE_COMPOSE_AND_LIST_ENABLED": "true",
        "GITHUB_CLIENT_ID": "Ov23lirHI1DWTzZ1zT1u",
        "GITHUB_CLIENT_SECRET": "staging-unconfigured",
        "OPENAUTH_CLIENT_ID": "openagents-web",
        "OPENAUTH_ISSUER_URL": "https://auth.openagents.com",
        "OPENAGENTS_APP_URL": "https://openagents-staging.openagents.workers.dev",
        "MDK_CHECKOUT_CONFIG_REF": "config.openagents.mdk.cloudflare_container",
        "MDK_CHECKOUT_CREDENTIAL_BINDING_REF": "credential_binding.openagents.mdk.cloudflare_worker_binding",
        "MDK_CHECKOUT_ENVIRONMENT": "production",
        "MDK_CHECKOUT_PATH_BASE": "/checkout",
        "MDK_CHECKOUT_PROVIDER_REF": "provider.openagents.mdk.cloudflare_container",
