        "MDK_CHECKOUT_WEBHOOK_SOURCE": "sdk_node_control",
        "SHC_DISPATCH_MODE": "unconfigured",
      },
      "kv_namespaces": [
        {
          "binding": "AUTH_STORAGE",
          "id": "586eb41c0d69448a96ffabaa5fc9bafd",
          "preview_id": "586eb41c0d69448a96ffabaa5fc9bafd",
        },
      ],
      "assets": {
        "directory": "../../apps/web/dist",
        "binding": "ASSETS",
