#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
pylon_root="$(cd "$script_dir/.." && pwd)"
binary="$pylon_root/swift/foundation-bridge/.build/release/foundation-bridge"

if [[ ! -x "$binary" ]]; then
  echo "foundation-bridge binary not found at $binary" >&2
  echo "Run apps/pylon/swift/foundation-bridge/build.sh first." >&2
  exit 1
fi

exec "$binary" "$@"
