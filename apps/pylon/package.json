{
  "name": "@openagentsinc/pylon",
  "version": "1.0.5",
  "private": false,
  "description": "Headless, CLI-only Pylon contributor node built on Node and Effect",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenAgentsInc/pylon.git"
  },
  "bin": {
    "pylon": "src/index.ts",
    "pylon-foundation-bridge": "bin/foundation-bridge"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "effect": "4.0.0-beta.94",
      "typescript": "^6.0.3"
    }
  },
  "files": [
    "src",
    "bin/foundation-bridge",
    "swift/foundation-bridge/Package.swift",
    "swift/foundation-bridge/README.md",
    "swift/foundation-bridge/build.sh",
    "swift/foundation-bridge/Sources",
    "packages/runtime/src",
    "packages/runtime/package.json",
    "docs/images/pylon.png",
    "docs/*.md",
    "docs/benchmarks",
    "docs/probe-port",
    "README.md",
    "LICENSE"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "type": "module",
  "main": "src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "runtime": "node --import tsx packages/runtime/src/cli.ts",
    "runtime:test": "pnpm --dir packages/runtime run test",
    "smoke:default-start": "rm -f /tmp/pylon-default-start.log; perl -e 'alarm 3; $ENV{PYLON_DISABLE_OPENCODE_STARTUP}=1; exec @ARGV' node --import tsx src/index.ts > /tmp/pylon-default-start.log 2>&1; code=$?; if [ \"$code\" -ne 142 ] && [ \"$code\" -ne 0 ]; then cat /tmp/pylon-default-start.log; exit \"$code\"; fi; if rg -n 'TypeError|Effect\\.(fork|catchAll)|is not a function|\\[ERROR\\]' /tmp/pylon-default-start.log; then exit 1; fi; printf 'default startup reached persistent mode without startup API errors\\n'",
    "smoke:live-worker-loop": "node --import tsx scripts/live-worker-loop-smoke.ts",
    "smoke:fleet-run-live": "node --import tsx scripts/fleet-run-live-smoke.ts",
    "smoke:fleet-run-sustained": "node --import tsx scripts/fleet-run-sustained-smoke.ts",
    "smoke:install:local": "bash scripts/smoke-local-package-install.sh",
    "smoke:packaged-network": "node --import tsx scripts/packaged-live-network-smoke.ts",
    "smoke:packaged-runtime-task": "node --import tsx scripts/packaged-runtime-task-smoke.ts",
    "smoke:claude-agent-task": "node --import tsx scripts/claude-agent-task-smoke.ts",
    "smoke:claude-owner-local-permission": "node --import tsx scripts/claude-owner-local-permission-smoke.ts",
    "smoke:mixed-harness-fleet-run": "node --import tsx scripts/mixed-harness-fleet-run-smoke.ts",
    "smoke:codex-agent-task": "node --import tsx scripts/codex-agent-task-smoke.ts",
    "build:apple-fm-bridge": "bash swift/foundation-bridge/build.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests:baseline": "node scripts/typecheck-tests.mjs",
    "typecheck:tests:update-baseline": "node scripts/typecheck-tests.mjs --update-baseline",
    "test": "vp test --run --root ../.. apps/pylon/scripts/typecheck-tests.test.mjs && pnpm run check:supervisor-store && vp test --run --max-concurrency=1 --root ../.. apps/pylon",
    "check:supervisor-store": "node --import tsx scripts/check-supervisor-store-bypass.mjs",
    "release:gate": "bash scripts/release-gate.sh",
    "build:rc-binaries": "bash scripts/build-rc-binaries.sh"
  },
  "dependencies": {
    "@openagentsinc/agent-runtime-schema": "0.2.1-rc.4",
    "@openagentsinc/autopilot-control-protocol": "workspace:*",
    "@openagentsinc/blueprint-contracts": "workspace:*",
    "@openagentsinc/effect-boundary": "workspace:*",
    "@openagentsinc/environment-auth": "workspace:*",
    "@openagentsinc/forge-protocol": "workspace:*",
    "@openagentsinc/grok-harness": "workspace:*",
    "@openagentsinc/khala-fleet-intents": "workspace:*",
    "@openagentsinc/khala-sync": "workspace:*",
    "@openagentsinc/khala-sync-server": "workspace:*",
    "@openagentsinc/khala-tools": "workspace:*",
    "@openagentsinc/mcp-contract": "workspace:*",
    "@openagentsinc/nip90": "workspace:*",
    "@openagentsinc/portable-session-contract": "workspace:*",
    "@openagentsinc/provider-account-schema": "workspace:*",
    "@openagentsinc/pylon-core": "workspace:*",
    "@openagentsinc/runtime-platform": "workspace:*",
    "@openagentsinc/sqlite-runtime": "workspace:*",
    "diff": "^9.0.0",
    "effect": "catalog:",
    "marked": "^18.0.5",
    "typescript": "5.9.2",
    "typescript-language-server": "5.3.0"
  },
  "devDependencies": {
    "@openagentsinc/durable-stream": "workspace:*",
    "fast-check": "^4.8.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.172",
    "@openai/codex-sdk": "^0.144.1",
    "mysql2": "^3.11.0"
  },
  "packageManager": "pnpm@11.10.0"
}
