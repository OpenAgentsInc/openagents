{
  "name": "@openagentsinc/khala",
  "version": "0.1.22",
  "private": false,
  "description": "Khala terminal client with interactive and headless CLI modes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenAgentsInc/openagents.git",
    "directory": "clients/khala-cli"
  },
  "bin": {
    "khala": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack src/index.ts --format esm --platform node --out-dir dist",
    "khala": "node --import tsx src/index.ts",
    "prepack": "pnpm run build",
    "test": "vp test --run src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openagentsinc/khala-tools": "workspace:*",
    "@openagentsinc/runtime-platform": "workspace:*",
    "@openai/codex-sdk": "^0.144.1"
  },
  "devDependencies": {
    "effect": "4.0.0-beta.94",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.10.0"
}
