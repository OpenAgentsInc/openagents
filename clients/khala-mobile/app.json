{
  "expo": {
    "name": "Khala Code",
    "slug": "khala-mobile",
    "scheme": "khala",
    "version": "0.1.0",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#02060d"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://updates.openagents.com/khala-mobile/manifest",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "ios": {
      "appleTeamId": "HQWSG26L43",
      "bundleIdentifier": "com.openagents.khala.mobile",
      "buildNumber": "21",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Khala uses the microphone for push-to-talk transcription.",
        "NSSpeechRecognitionUsageDescription": "Khala uses on-device speech recognition to transcribe push-to-talk input.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.openagents.khala.mobile",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#02060d"
      },
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "expo-updates",
      "./plugins/with-storybook-ios-build-fixes.cjs",
      "./modules/khala-push-to-talk-stt/app.plugin.js",
      "./modules/khala-apple-foundation-models/app.plugin.js",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#4fd0ff"
        }
      ],
      "expo-font",
      "react-native-edge-to-edge"
    ],
    "extra": {
      "khala": {
        "apiBaseUrl": "https://openagents.com",
        "authBaseUrl": "https://auth.openagents.com",
        "syncBaseUrl": "https://openagents.com",
        "updatesOwner": "khala-mobile"
      }
    }
  }
}
