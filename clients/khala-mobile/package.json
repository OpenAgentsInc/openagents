{
  "name": "@openagentsinc/khala-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.tsx",
  "scripts": {
    "dev": "expo start",
    "prebuild": "expo prebuild",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:android": "expo prebuild --platform android",
    "build:ios:local": "xcodebuild -workspace ios/KhalaCode.xcworkspace -scheme KhalaCode -configuration Debug -destination 'generic/platform=iOS Simulator' build",
    "build:android:local": "./android/gradlew -p android :app:assembleDebug",
    "export:ota:ios": "expo export --platform ios --output-dir ../../apps/oa-updates/dist",
    "export:ota:android": "expo export --platform android --output-dir ../../apps/oa-updates/dist",
    "publish:ota": "bash ../../apps/oa-updates/scripts/publish-ota.sh",
    "assets:generate": "bash scripts/generate-assets.sh",
    "architecture:check": "depcruise index.tsx src tests --config .dependency-cruiser.cjs",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-config": "57.0.3",
    "@expo/metro-runtime": "57.0.3",
    "@openagentsinc/behavior-contracts": "workspace:*",
    "@openagentsinc/khala-sync": "workspace:*",
    "@openagentsinc/khala-sync-client": "workspace:*",
    "@openagentsinc/khala-sync-db-collection": "workspace:*",
    "@openagentsinc/ui": "workspace:*",
    "@react-navigation/drawer": "^7.6.2",
    "@react-navigation/native": "^7.3.1",
    "@react-navigation/native-stack": "^7.2.0",
    "@shopify/react-native-skia": "2.6.2",
    "@tanstack/db": "0.6.14",
    "effect": "catalog:",
    "expo": "57.0.2",
    "expo-auth-session": "~57.0.1",
    "expo-clipboard": "57.0.0",
    "expo-constants": "57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-device": "^57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "57.0.0",
    "expo-linking": "57.0.1",
    "expo-modules-core": "57.0.2",
    "expo-notifications": "57.0.3",
    "expo-secure-store": "57.0.0",
    "expo-sqlite": "57.0.0",
    "expo-status-bar": "57.0.0",
    "expo-system-ui": "57.0.0",
    "expo-updates": "57.0.6",
    "expo-web-browser": "~57.0.0",
    "khala-apple-foundation-models": "file:./modules/khala-apple-foundation-models",
    "khala-push-to-talk-stt": "file:./modules/khala-push-to-talk-stt",
    "nativewind": "4.2.6",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-css-interop": "0.2.6",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-gesture-handler": "3.0.2",
    "react-native-keyboard-controller": "^1.21.14",
    "react-native-reanimated": "4.5.1",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.10.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/plugin-transform-react-jsx": "7.29.7",
    "@expo/config-plugins": "57.0.2",
    "@react-native/babel-preset": "0.86.0",
    "@types/babel__core": "7.20.5",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "19.1.0",
    "babel-preset-expo": "57.0.1",
    "dependency-cruiser": "^17.0.2",
    "react-test-renderer": "19.2.7",
    "tailwindcss": "3.4.19",
    "typescript": "catalog:"
  }
}
