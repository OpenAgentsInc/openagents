{
  "name": "@openagentsinc/khala-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "prebuild": "expo prebuild",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:android": "expo prebuild --platform android",
    "build:ios:local": "xcodebuild -workspace ios/Khala.xcworkspace -scheme Khala -configuration Debug -destination 'generic/platform=iOS Simulator' build",
    "build:android:local": "./android/gradlew -p android :app:assembleDebug",
    "export:ota:ios": "expo export --platform ios --output-dir ../../apps/oa-updates/dist",
    "export:ota:android": "expo export --platform android --output-dir ../../apps/oa-updates/dist",
    "publish:ota": "bash ../../apps/oa-updates/scripts/publish-ota.sh",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@expo/metro-config": "57.0.3",
    "@expo/metro-runtime": "57.0.3",
    "@openagentsinc/khala-sync": "workspace:*",
    "@openagentsinc/khala-sync-client": "workspace:*",
    "@openagentsinc/khala-sync-db-collection": "workspace:*",
    "@openagentsinc/ui": "workspace:*",
    "@tanstack/db": "0.6.14",
    "expo": "57.0.2",
    "expo-constants": "57.0.3",
    "expo-device": "^57.0.0",
    "expo-linking": "57.0.1",
    "expo-modules-core": "57.0.2",
    "expo-router": "57.0.3",
    "expo-secure-store": "57.0.0",
    "expo-sqlite": "57.0.0",
    "expo-status-bar": "57.0.0",
    "expo-system-ui": "57.0.0",
    "expo-updates": "57.0.6",
    "khala-apple-foundation-models": "file:./modules/khala-apple-foundation-models",
    "khala-push-to-talk-stt": "file:./modules/khala-push-to-talk-stt",
    "nativewind": "4.2.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-css-interop": "0.2.6",
    "react-native-gesture-handler": "3.0.2",
    "react-native-reanimated": "4.5.1",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.10.1",
    "react-server-dom-webpack": "19.2.4"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "7.29.7",
    "@expo/config-plugins": "57.0.2",
    "@types/react": "^19.2.14",
    "babel-preset-expo": "57.0.1",
    "react-test-renderer": "19.2.7",
    "tailwindcss": "3.4.19",
    "typescript": "catalog:"
  }
}
