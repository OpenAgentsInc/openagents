import type { ReactNode } from "react"
import { View } from "react-native"

import { KhalaText } from "./khala-text"

type NAMEProps = Readonly<{
  children?: ReactNode
  state?: "active" | "idle"
  title: string
}>

export const NAME = ({ children, state = "idle", title }: NAMEProps) => (
  <View className="gap-2">
    <KhalaText text={title} variant="label" />
    <KhalaText text={state === "active" ? "Active" : "Idle"} variant="body" />
    {children}
  </View>
)
