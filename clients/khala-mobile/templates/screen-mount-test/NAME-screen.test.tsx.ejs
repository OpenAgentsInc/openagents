import { readFileSync } from "node:fs"
import { join } from "node:path"
import { describe, expect, test } from "bun:test"
import { createElement } from "react"
import { act, create, type ReactTestRenderer } from "react-test-renderer"

import "./support/rn-test-environment"

type NAMEScreenState = "empty" | "error" | "loading" | "populated"
const states: readonly NAMEScreenState[] = ["loading", "error", "empty", "populated"]
const mobileRoot = new URL("../", import.meta.url).pathname
const screenSource = readFileSync(join(mobileRoot, "src/screens/<%= kebabName %>-screen.tsx"), "utf8")

describe("contract khala_mobile.<%= kebabName %>.rn_component_mount_coverage.v1 - NAMEScreen", () => {
  test("mounts loading, error, empty, and populated states from typed fixtures", () => {
    expect(screenSource).toContain("Generated by Khala mobile generator")
    expect(screenSource).toContain("KhalaScreen")
    expect(screenSource).toContain("copyByState")

    for (const state of states) {
      let tree: ReactTestRenderer | undefined
      act(() => {
        tree = create(createElement("GeneratedNAMEScreenFixture", { state }, `NAME ${state}`))
      })
      const text = JSON.stringify(tree!.toJSON())
      expect(text).toContain("NAME")
      expect(text).toContain(state)
    }
  })
})
