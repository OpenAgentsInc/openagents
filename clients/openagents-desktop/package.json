{
  "name": "@openagentsinc/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun build src/ui/main.ts --outdir resources/ui --target browser && electrobun dev",
    "build:ui": "bun build src/ui/main.ts --outdir resources/ui --target browser",
    "build": "bun run build:ui && electrobun build",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "bun test tests/*.test.ts",
    "verify": "bun run typecheck && bun test tests/*.test.ts && bun run build:ui && bun build src/bun/index.ts --outdir /tmp/openagents-desktop-bun-build --target bun"
  },
  "dependencies": {
    "@openagentsinc/three-effect": "github:OpenAgentsInc/three-effect#b3bdc2a",
    "effect": "catalog:",
    "electrobun": "1.18.1",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@types/three": "0.184.0",
    "bun-types": "^1.0.0",
    "typescript": "catalog:"
  }
}
