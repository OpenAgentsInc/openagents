# OpenAgents Cloud GCP node bootstrap template.
# Copy to an untracked environment file before use.

OPENAGENTS_CLOUD_ENV=dev
OPENAGENTS_GCP_PROJECT=replace-with-project-id
OPENAGENTS_GCP_REGION=us-central1
OPENAGENTS_GCP_ZONE=us-central1-a
OPENAGENTS_GCP_NODE_NAME=oa-node-dev-01
OPENAGENTS_GCP_IMAGE_TAG=local

# Secret references only. Do not put raw tokens, keys, or auth JSON here.
OPENAGENTS_NODE_SIGNING_KEY_REF=gcp-secret://oa-node-dev-signing-key
OPENAGENTS_CODEX_PROVIDER_SECRET_REF=gcp-secret://codex/account/dev
