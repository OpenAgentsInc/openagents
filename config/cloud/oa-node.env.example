# OpenAgents managed node environment template.
# Copy to an untracked file such as .secrets/oa-node.env before use.

OPENAGENTS_CLOUD_NODE_ORG=org.openagents.test
OPENAGENTS_CLOUD_NODE_ID=oa-node-dev-01
OPENAGENTS_CLOUD_NODE_STATE_DIR=/var/lib/openagents/oa-node
OPENAGENTS_CLOUD_DESIRED_MODE=offline

# References only. Raw secret values stay in the host secret manager or local
# ignored .secrets/ files.
OPENAGENTS_CLOUD_SIGNING_KEY_REF=gcp-secret://oa-node-dev-signing-key
OPENAGENTS_CLOUD_SECRET_POLICY=brokered_no_raw_secrets
OPENAGENTS_CLOUD_LOG_REDACTION=broker_redact_required
