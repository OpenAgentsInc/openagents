# OpenAgents workroom sidecar environment template.
# Copy to an untracked file such as .secrets/oa-workroomd.env before use.

OPENAGENTS_CLOUD_WORKROOM_HOME=/var/lib/openagents/workrooms/default
OPENAGENTS_CLOUD_WORKROOM_VISIBILITY=private
OPENAGENTS_CLOUD_WORKROOM_WALLET_AUTHORITY=false
OPENAGENTS_CLOUD_WORKROOM_SECRET_POLICY=brokered_no_raw_secrets
OPENAGENTS_CLOUD_WORKROOM_ARTIFACT_POLICY=required_closeout

# References only. Raw Codex auth material is brokered into a per-run session
# home and scrubbed after use.
OPENAGENTS_CODEX_PROVIDER_ACCOUNT_REF=provider-account-dev
OPENAGENTS_CODEX_PROVIDER_SECRET_REF=gcp-secret://codex/account/dev
