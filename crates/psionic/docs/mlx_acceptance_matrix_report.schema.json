{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openagents.dev/psionic/mlx_acceptance_matrix_report.schema.json",
  "title": "Psionic MLX Acceptance Matrix Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "runner",
    "report_posture",
    "selected_categories",
    "categories",
    "report_digest"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "schema_path": {
      "type": "string",
      "const": "crates/psionic/docs/mlx_acceptance_matrix_report.schema.json"
    },
    "runner": {
      "type": "string",
      "const": "scripts/release/check-psionic-mlx-acceptance-matrix.sh"
    },
    "report_posture": {
      "type": "string",
      "enum": [
        "tracking_only"
      ]
    },
    "selected_categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "array-runtime-surface",
          "transform-compile",
          "nn-optimizer",
          "export-serialization-tooling",
          "distributed-semantics",
          "backend-closure"
        ]
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "report_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category_id",
        "matrix_status",
        "epic_id",
        "issue_refs",
        "green_definition",
        "current_repo_truth",
        "boundary_note"
      ],
      "properties": {
        "category_id": {
          "type": "string",
          "enum": [
            "array-runtime-surface",
            "transform-compile",
            "nn-optimizer",
            "export-serialization-tooling",
            "distributed-semantics",
            "backend-closure"
          ]
        },
        "matrix_status": {
          "type": "string",
          "enum": [
            "implemented",
            "implemented_early",
            "partial",
            "partial_outside_psionic",
            "planned"
          ]
        },
        "epic_id": {
          "type": "string",
          "enum": [
            "PMLX-E1",
            "PMLX-E2",
            "PMLX-E3",
            "PMLX-E4",
            "PMLX-E5",
            "PMLX-E6"
          ]
        },
        "issue_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "green_definition": {
          "type": "string",
          "minLength": 1
        },
        "current_repo_truth": {
          "type": "string",
          "minLength": 1
        },
        "boundary_note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
