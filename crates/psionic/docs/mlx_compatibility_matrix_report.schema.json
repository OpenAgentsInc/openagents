{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openagents.dev/psionic/mlx_compatibility_matrix_report.schema.json",
  "title": "Psionic MLX Compatibility Matrix Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "runner",
    "oracle_window",
    "selected_surfaces",
    "surfaces",
    "report_digest"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "schema_path": {
      "type": "string",
      "const": "crates/psionic/docs/mlx_compatibility_matrix_report.schema.json"
    },
    "runner": {
      "type": "string",
      "const": "scripts/release/check-psionic-mlx-compatibility-matrix.sh"
    },
    "oracle_window": {
      "type": "string",
      "const": "ml-explore/mlx:v0.31.0..v0.31.1:matrix_v0"
    },
    "selected_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "governance_contracts",
          "seeded_transform_compile_export_parity_anchors",
          "graph_first_function_export_bridge",
          "portable_model_io_bridge",
          "module_state_tree_bridge",
          "public_mlx_array_api",
          "public_mlx_transform_api",
          "public_mlx_nn_optimizer_api",
          "mlxfn_interop",
          "mlx_naming_facade_and_bindings",
          "public_mlx_distributed_api",
          "mlx_package_ecosystem"
        ]
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface"
      }
    },
    "report_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "matrix_status",
        "summary",
        "evidence_refs",
        "blocking_issue_refs",
        "boundary_note"
      ],
      "properties": {
        "surface_id": {
          "type": "string",
          "enum": [
            "governance_contracts",
            "seeded_transform_compile_export_parity_anchors",
            "graph_first_function_export_bridge",
            "portable_model_io_bridge",
            "module_state_tree_bridge",
            "public_mlx_array_api",
            "public_mlx_transform_api",
            "public_mlx_nn_optimizer_api",
            "mlxfn_interop",
            "mlx_naming_facade_and_bindings",
            "public_mlx_distributed_api",
            "mlx_package_ecosystem"
          ]
        },
        "matrix_status": {
          "type": "string",
          "enum": [
            "supported",
            "convertible",
            "unsupported"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocking_issue_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "boundary_note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
