{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openagents.dev/psionic/mlx_cpu_reference_coverage_report.schema.json",
  "title": "Psionic MLX CPU Reference Coverage Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "runner",
    "oracle_window",
    "current_scope_window",
    "cases",
    "report_digest",
    "selected_families"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "schema_path": {
      "type": "string",
      "const": "crates/psionic/docs/mlx_cpu_reference_coverage_report.schema.json"
    },
    "runner": {
      "type": "string",
      "const": "scripts/release/check-psionic-mlx-cpu-reference-coverage.sh"
    },
    "oracle_window": {
      "type": "string",
      "const": "ml-explore/mlx:v0.31.0..v0.31.1:cpu_reference_seed_v1"
    },
    "current_scope_window": {
      "type": "string",
      "const": "psionic_mlx_cpu_reference_v1"
    },
    "selected_families": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "array_core",
          "ops_numeric",
          "device_eval_memory"
        ]
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    },
    "report_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "tensorSpec": {
      "type": "object",
      "required": [
        "shape",
        "dtype",
        "device"
      ]
    },
    "psionicRefusal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "scope",
        "detail"
      ],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "unsupported_op",
            "unsupported_gradient",
            "unsupported_layout",
            "unsupported_backend_capability",
            "serialization_incompatibility",
            "sandbox_policy_denied",
            "topology_mismatch"
          ]
        },
        "scope": {
          "type": "string",
          "enum": [
            "graph",
            "autodiff",
            "runtime",
            "sandbox",
            "topology"
          ]
        },
        "subject": {
          "type": "string"
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "family_id",
        "upstream_sources",
        "surface_label",
        "capability_profile",
        "input_specs",
        "status",
        "bounded_scope"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "family_id": {
          "type": "string",
          "enum": [
            "array_core",
            "ops_numeric",
            "device_eval_memory"
          ]
        },
        "upstream_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "surface_label": {
          "type": "string",
          "minLength": 1
        },
        "capability_profile": {
          "type": "string",
          "const": "cpu_reference_dense_public_array_v1"
        },
        "input_specs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tensorSpec"
          }
        },
        "expected_output": {
          "$ref": "#/$defs/tensorSpec"
        },
        "actual_output": {
          "$ref": "#/$defs/tensorSpec"
        },
        "expected_refusal": {
          "$ref": "#/$defs/psionicRefusal"
        },
        "actual_refusal": {
          "$ref": "#/$defs/psionicRefusal"
        },
        "status": {
          "type": "string",
          "enum": [
            "supported",
            "refused"
          ]
        },
        "bounded_scope": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
