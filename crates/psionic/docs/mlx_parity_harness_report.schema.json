{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openagents.dev/psionic/mlx_parity_harness_report.schema.json",
  "title": "Psionic MLX Parity Harness Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "runner",
    "oracle_window",
    "selected_families",
    "families",
    "report_digest"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "schema_path": {
      "type": "string",
      "const": "crates/psionic/docs/mlx_parity_harness_report.schema.json"
    },
    "runner": {
      "type": "string",
      "const": "scripts/release/check-psionic-mlx-parity-harness.sh"
    },
    "oracle_window": {
      "type": "string",
      "const": "ml-explore/mlx:v0.31.0..v0.31.1:seed_v0"
    },
    "selected_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "array_core",
          "ops_numeric",
          "device_eval_memory",
          "autograd",
          "vmap_custom_vjp",
          "compile",
          "export_import",
          "nn_optimizers_quantized",
          "distributed"
        ]
      }
    },
    "families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/family"
      }
    },
    "report_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "family": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_id",
        "acceptance_category",
        "upstream_sources",
        "current_outcome",
        "psionic_hook_commands",
        "summary",
        "boundary_note"
      ],
      "properties": {
        "family_id": {
          "type": "string",
          "enum": [
            "array_core",
            "ops_numeric",
            "device_eval_memory",
            "autograd",
            "vmap_custom_vjp",
            "compile",
            "export_import",
            "nn_optimizers_quantized",
            "distributed"
          ]
        },
        "acceptance_category": {
          "type": "string",
          "enum": [
            "array-runtime-surface",
            "transform-compile",
            "nn-optimizer",
            "export-serialization-tooling",
            "distributed-semantics",
            "backend-closure"
          ]
        },
        "upstream_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "current_outcome": {
          "type": "string",
          "enum": [
            "pass",
            "refusal",
            "unsupported"
          ]
        },
        "psionic_hook_commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "boundary_note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
