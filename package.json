{
  "name": "openagents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": {
    "packages": [
      "apps/openagents.com",
      "apps/openagents.com/apps/*",
      "apps/openagents.com/packages/*",
      "apps/openagents.com/services/*",
      "apps/openagents.com/workers/*",
      "apps/acceptance-runner",
      "apps/qa-runner",
      "apps/autopilot-desktop",
      "apps/forum",
      "apps/oa-updates",
      "apps/nostr-relay",
      "apps/openagents-world",
      "apps/pylon",
      "apps/pylon/packages/*",
      "clients/mobile/*",
      "packages/*",
      "packages/probe",
      "packages/probe/packages/*"
    ],
    "catalog": {
      "effect": "4.0.0-beta.70",
      "typescript": "^6.0.3"
    }
  },
  "scripts": {
    "dev:openagents.com": "bun run --cwd apps/openagents.com dev",
    "dev:forum": "bun run --cwd apps/forum dev",
    "dev:nostr-relay": "bun run --cwd apps/nostr-relay dev",
    "dev:openagents-world": "bun run --cwd apps/openagents-world dev",
    "dev:pylon": "bun run --cwd apps/pylon start",
    "deploy:nostr-relay": "bun run --cwd apps/nostr-relay deploy",
    "deploy:openagents-world": "bun run --cwd apps/openagents-world deploy",
    "smoke:nostr-relay": "bun run --cwd apps/nostr-relay smoke",
    "test": "bun run test:qa-pre-push-smoke && bun run test:forum && bun run test:pylon && bun run test:probe && bun run test:qa-runner && bun run test:nip90 && bun run test:proof-replay && bun run test:public-activity-timeline && bun run test:input-bindings && bun run test:design-tokens && bun run test:ui && bun run test:replay-clips && bun run test:agent-runtime-schema && bun run test:provider-account-schema && bun run test:blueprint-contracts && bun run test:mcp-contract && bun run test:world-contract && bun run test:world-client && bun run test:openagents-world && bun run test:autopilot-ui && bun run test:oa-updates && bun run test:nostr-relay && bun run test:durable-stream",
    "verify:autopilot-desktop:training": "bun run --cwd apps/autopilot-desktop verify:training",
    "test:openagents.com": "bun run --cwd apps/openagents.com test",
    "test:forum": "bun run --cwd apps/forum test",
    "test:pylon": "bun run --cwd apps/pylon test",
    "test:probe": "bun run --cwd packages/probe test",
    "test:qa-runner": "bun run --cwd apps/qa-runner test",
    "test:nip90": "bun run --cwd packages/nip90 test",
    "test:proof-replay": "bun run --cwd packages/proof-replay test",
    "test:public-activity-timeline": "bun run --cwd packages/public-activity-timeline test",
    "test:input-bindings": "bun run --cwd packages/input-bindings test",
    "test:design-tokens": "bun run --cwd packages/design-tokens test",
    "test:replay-clips": "bun run --cwd packages/replay-clips test",
    "test:ui": "bun run --cwd packages/ui test",
    "test:agent-runtime-schema": "bun run --cwd packages/agent-runtime-schema test",
    "test:provider-account-schema": "bun run --cwd packages/provider-account-schema test",
    "test:blueprint-contracts": "bun run --cwd packages/blueprint-contracts test",
    "test:mcp-contract": "bun run --cwd packages/mcp-contract test",
    "test:world-contract": "bun run --cwd packages/world-contract test",
    "test:world-client": "bun run --cwd packages/world-client test",
    "test:openagents-world": "bun run --cwd apps/openagents-world test",
    "test:autopilot-ui": "bun run --cwd packages/autopilot-ui test",
    "test:oa-updates": "bun run --cwd apps/oa-updates test",
    "test:nostr-relay": "bun run --cwd apps/nostr-relay test",
    "test:durable-stream": "bun run --cwd packages/durable-stream test",
    "test:qa-pre-push-smoke": "bun test scripts/qa-pre-push-smoke.test.ts",
    "check:deploy": "bun run --cwd apps/openagents.com check:deploy",
    "typecheck": "bun run typecheck:forum && bun run typecheck:nostr-relay && bun run typecheck:openagents-world && bun run typecheck:nip90 && bun run typecheck:proof-replay && bun run typecheck:public-activity-timeline && bun run typecheck:input-bindings && bun run typecheck:design-tokens && bun run typecheck:replay-clips && bun run typecheck:ui && bun run typecheck:agent-runtime-schema && bun run typecheck:provider-account-schema && bun run typecheck:blueprint-contracts && bun run typecheck:mcp-contract && bun run typecheck:world-contract && bun run typecheck:world-client && bun run typecheck:autopilot-ui && bun run typecheck:durable-stream",
    "typecheck:forum": "bun run --cwd apps/forum typecheck",
    "typecheck:nostr-relay": "bun run --cwd apps/nostr-relay typecheck",
    "typecheck:openagents-world": "bun run --cwd apps/openagents-world typecheck",
    "typecheck:nip90": "bun run --cwd packages/nip90 typecheck",
    "typecheck:proof-replay": "bun run --cwd packages/proof-replay typecheck",
    "typecheck:public-activity-timeline": "bun run --cwd packages/public-activity-timeline typecheck",
    "typecheck:input-bindings": "bun run --cwd packages/input-bindings typecheck",
    "typecheck:design-tokens": "bun run --cwd packages/design-tokens typecheck",
    "typecheck:replay-clips": "bun run --cwd packages/replay-clips typecheck",
    "typecheck:ui": "bun run --cwd packages/ui typecheck",
    "typecheck:agent-runtime-schema": "bun run --cwd packages/agent-runtime-schema typecheck",
    "typecheck:provider-account-schema": "bun run --cwd packages/provider-account-schema typecheck",
    "typecheck:blueprint-contracts": "bun run --cwd packages/blueprint-contracts typecheck",
    "typecheck:mcp-contract": "bun run --cwd packages/mcp-contract typecheck",
    "typecheck:world-contract": "bun run --cwd packages/world-contract typecheck",
    "typecheck:world-client": "bun run --cwd packages/world-client typecheck",
    "typecheck:autopilot-ui": "bun run --cwd packages/autopilot-ui typecheck",
    "typecheck:durable-stream": "bun run --cwd packages/durable-stream typecheck",
    "verify:autopilot-desktop:deploy": "bun run --cwd apps/autopilot-desktop verify:deploy",
    "verify:autopilot-desktop:if-changed": "bun run --cwd apps/autopilot-desktop run scripts/run-if-desktop-changed.ts -- bun run verify:deploy",
    "prepare": "effect-language-service patch"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@playwright/test": "^1.61.0",
    "bun-types": "^1.0.0",
    "playwright": "^1.61.0",
    "typescript": "catalog:"
  },
  "trustedDependencies": [
    "electrobun"
  ]
}
