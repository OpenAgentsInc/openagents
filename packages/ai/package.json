{
  "name": "@openagentsinc/ai",
  "version": "0.1.0",
  "private": false,
  "description": "OpenAgents AI SDK umbrella package. Curated re-exports of the SDK layer entry points.",
  "license": "MIT",
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./model": "./src/model.ts",
    "./schema": "./src/schema.ts",
    "./event-log": "./src/event-log.ts",
    "./sandbox": "./src/sandbox.ts",
    "./harness": "./src/harness.ts",
    "./ui-stream": "./src/ui-stream.ts",
    "./recall": "./src/recall.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vp test --run packages/ai/src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openagentsinc/agent-harness-contract": "workspace:*",
    "@openagentsinc/agent-runtime-schema": "workspace:*",
    "@openagentsinc/ai-model": "workspace:*",
    "@openagentsinc/history-corpus": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
