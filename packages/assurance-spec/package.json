{
  "name": "@openagentsinc/assurance-spec",
  "version": "0.1.1",
  "private": false,
  "bin": {
    "assurance-spec": "./src/cli.ts"
  },
  "files": [
    "src",
    "skills",
    "starter-kit",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/browser.ts",
    "./execution": "./src/execution.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "assure:mvp": "node --import tsx scripts/run-mvp-assurance.ts",
    "test": "vp test --run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:public": "node --import tsx scripts/pack-public.ts",
    "verify:distribution": "node --import tsx scripts/verify-distribution.ts"
  },
  "dependencies": {
    "@openagentsinc/product-spec": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
