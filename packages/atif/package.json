{
  "name": "@openagentsinc/atif",
  "version": "0.1.0",
  "private": false,
  "description": "Canonical in-repo ATIF (Agent Trajectory Interchange Format, ATIF-v1.7) schema, validators, and public-safety tripwire shared by trace producers (qa-runner) and consumers (the trace ingest API).",
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./trace": "./src/trace-schema.ts",
    "./emit": "./src/emit.ts",
    "./validate": "./src/validate.ts",
    "./redaction": "./src/redaction.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vp test --run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
