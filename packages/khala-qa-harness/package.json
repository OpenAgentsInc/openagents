    "monkey:smoke": "bun test src/monkey-explorer.test.ts --test-name-pattern 'bounded fixture smoke'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openagentsinc/khala-code-desktop": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "bun-types": "^1.0.0",
    "fast-check": "^4.8.0",
    "typescript": "catalog:",
    "vitest": "^4.1.8"
  }
}
