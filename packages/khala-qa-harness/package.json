{
  "name": "@openagentsinc/khala-qa-harness",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./coverage-ledger": "./src/coverage-ledger.ts",
    "./deterministic-env": "./src/deterministic-env.ts",
    "./desktop-smoke-helpers": "./src/desktop-smoke-helpers.ts",
    "./driver": "./src/driver.ts",
    "./explore-distiller": "./src/explore-distiller.ts",
    "./explore-policy-gepa": "./src/explore-policy-gepa.ts",
    "./explorer-brain": "./src/explorer-brain.ts",
    "./lag-profiling-sweep": "./src/lag-profiling-sweep.ts",
    "./live-explorer": "./src/live-explorer.ts",
    "./memory-oracle": "./src/memory-oracle.ts",
    "./monkey-explorer": "./src/monkey-explorer.ts",
    "./rpc-driver": "./src/rpc-driver.ts",
    "./rpc-client": "./src/rpc-client.ts",
    "./runner": "./src/runner.ts",
    "./scenario": "./src/scenario.ts",
    "./visual-baseline": "./src/visual-baseline.ts"
  },
  "scripts": {
    "test": "bun test src/*.test.ts",
    "lag:sweep": "bun src/lag-profiling-sweep.ts",
    "smoke:real-bridge": "bun src/real-bridge-smoke.ts",
    "smoke:architect-coder-judge-live": "bun src/architect-coder-judge-live-smoke.ts",
