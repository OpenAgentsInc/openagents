{
  "name": "@openagentsinc/khala-sync-server",
  "version": "0.1.0",
  "private": true,
  "files": [
    "src",
    "scripts",
    "migrations",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./capture": "./src/capture.ts",
    "./hub": "./src/hub.ts",
    "./migrate": "./src/migrate.ts",
    "./test/local-postgres": "./src/test/local-postgres.ts"
  },
  "scripts": {
    "compact": "node --import tsx scripts/compact.ts",
    "load-test": "node --import tsx scripts/load-test.ts",
    "migrate": "node --import tsx scripts/migrate.ts",
    "test": "vp test --run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.port03-production-driver.json --noEmit",
    "capture": "node --import tsx scripts/capture.ts",
    "check:pending-migrations": "node --import tsx scripts/check-pending-migrations.ts",
    "test:pending-migrations-guard": "vp test --run scripts/check-pending-migrations.test.ts"
  },
  "dependencies": {
    "@openagentsinc/khala-fleet-intents": "workspace:*",
    "@openagentsinc/khala-sync": "workspace:*",
    "@openagentsinc/portable-session-contract": "workspace:*",
    "@openagentsinc/postgres-runtime": "workspace:*",
    "effect": "catalog:",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@openagentsinc/runtime-platform": "workspace:*",
    "typescript": "catalog:"
  }
}
