{
  "name": "@openagentsinc/probe-runtime",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "probe": "./src/cli.ts"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./computer-use": "./src/computer-use/index.ts",
    "./computer-use/browser": "./src/computer-use/browser.ts",
    "./computer-use/node-pty": "./src/computer-use/node-pty.ts",
    "./computer-use/page": "./src/computer-use/page.ts",
    "./computer-use/playwright-page": "./src/computer-use/playwright-page.ts",
    "./computer-use/terminal": "./src/computer-use/terminal.ts",
    "./computer-use/terminal-snapshot": "./src/computer-use/terminal-snapshot.ts",
    "./openrouter": "./src/llm/openrouter.ts"
  },
  "scripts": {
    "probe": "node --import tsx src/cli.ts",
    "test": "vp test --run",
    "typecheck": "node scripts/verify-test-typecheck.mjs",
    "typecheck:baseline:update": "node scripts/verify-test-typecheck.mjs --update-baseline"
  },
  "dependencies": {
    "@openagentsinc/blueprint-contracts": "workspace:*",
    "@openagentsinc/provider-account-schema": "workspace:*",
    "@openagentsinc/runtime-platform": "workspace:*",
    "@openrouter/sdk": "^0.13.7",
    "@opentui/core": "0.3.4",
    "diff": "^9.0.0",
    "effect": "catalog:",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
