{
  "name": "@openagentsinc/pylon-core",
  "version": "0.1.0",
  "description": "Typed Effect engine services for Pylon — custody, executor, presence, and the Spark wallet rail — shared by the pylon/khala CLIs, the engine daemon, and Khala Code desktop",
  "private": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./shared": "./src/shared/index.ts",
    "./shared/*": "./src/shared/*.ts",
    "./custody": "./src/custody/index.ts",
    "./custody/*": "./src/custody/*.ts",
    "./executor": "./src/executor/index.ts",
    "./executor/*": "./src/executor/*.ts",
    "./rpc": "./src/rpc/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openagentsinc/agent-runtime-schema": "workspace:*",
    "@openagentsinc/effect-boundary": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.3.172",
    "@openai/codex-sdk": "^0.139.0",
    "@noble/curves": "1.8.1",
    "@noble/hashes": "1.7.1",
    "@scure/base": "1.2.4",
    "@scure/bip32": "1.6.2",
    "@scure/bip39": "1.5.4",
    "effect": "catalog:"
  },
  "devDependencies": {
    "bun-types": "^1.0.0",
    "typescript": "catalog:"
  }
}
