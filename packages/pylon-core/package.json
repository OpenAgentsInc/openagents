{
  "name": "@openagentsinc/pylon-core",
  "version": "0.1.0",
  "private": false,
  "description": "Typed Effect engine services for Pylon \u2014 custody, executor, presence, and the Spark wallet rail \u2014 shared by the pylon/khala CLIs, the engine daemon, and Khala Code desktop",
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./shared": "./src/shared/index.ts",
    "./shared/*": "./src/shared/*.ts",
    "./custody": "./src/custody/index.ts",
    "./custody/*": "./src/custody/*.ts",
    "./executor": "./src/executor/index.ts",
    "./executor/*": "./src/executor/*.ts",
    "./presence": "./src/presence/index.ts",
    "./presence/*": "./src/presence/*.ts",
    "./wallet": "./src/wallet/index.ts",
    "./wallet/*": "./src/wallet/*.ts",
    "./rpc": "./src/rpc/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vp test --run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.172",
    "@noble/curves": "1.8.1",
    "@noble/hashes": "1.7.1",
    "@openagentsinc/agent-runtime-schema": "0.1.3-rc.1",
    "@openagentsinc/effect-boundary": "workspace:*",
    "@openagentsinc/grok-harness": "workspace:*",
    "@openagentsinc/nip90": "workspace:*",
    "@openagentsinc/runtime-platform": "workspace:*",
    "@openagentsinc/sovereign-identity": "workspace:*",
    "@openai/codex-sdk": "^0.144.1",
    "@scure/base": "1.2.4",
    "@scure/bip32": "1.6.2",
    "@scure/bip39": "1.5.4",
    "effect": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
